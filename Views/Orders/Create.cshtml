@model GS_CookieOrder_Tracker.Models.OrderCreateViewModel

@{
    ViewData["Title"] = "New Order";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">New Order</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CustomerId" class="form-label">Customer</label>
                            <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select default-select"></select>
                            <span asp-validation-for="CustomerId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="GirlScoutId" class="form-label">Girl Scout</label>
                            <select asp-for="GirlScoutId" asp-items="Model.GirlScouts" class="form-select default-select"></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="OrderType" class="form-label">Order Type</label>
                            <input asp-for="OrderType" class="form-control" />
                            <span asp-validation-for="OrderType" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Status" class="form-label">Status</label>
                            <input asp-for="Status" class="form-control" />
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="OrderedAt" class="form-label">Order Date</label>
                            <input asp-for="OrderedAt" type="datetime-local" class="form-control" />
                            <span asp-validation-for="OrderedAt" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="DeliveryDate" class="form-label">Delivery Date</label>
                            <input asp-for="DeliveryDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-8 mb-3">
                            <label asp-for="Notes" class="form-label">Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <h5 class="card-title mt-4 mb-3">Line Item</h5>
                    <hr>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ProductId" class="form-label">Product</label>
                            <select asp-for="ProductId" asp-items="Model.Products" class="form-select default-select"></select>
                            <span asp-validation-for="ProductId" class="text-danger"></span>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="QuantityBoxes" class="form-label">Boxes</label>
                            <input asp-for="QuantityBoxes" class="form-control" />
                            <span asp-validation-for="QuantityBoxes" class="text-danger"></span>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="UnitPrice" class="form-label">Unit Price</label>
                            <input asp-for="UnitPrice" class="form-control" />
                            <span asp-validation-for="UnitPrice" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">Save Order</button>
                        <a class="btn btn-outline-light ms-2" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
