@model GS_CookieOrder_Tracker.Models.OrderCreateViewModel

@{
    ViewData["Title"] = "New Order";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">New Order</h4>
            </div>
            <div class="card-body">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="OrderType" class="form-label">Order Type</label>
                            <select asp-for="OrderType" asp-items="Model.OrderTypes" class="form-select" id="orderType"></select>
                            <span asp-validation-for="OrderType" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="CustomerId" class="form-label">
                                Customer
                                <a href="javascript:void(0)" id="openNewCustomerModal" class="ms-2 small label-info ps-1 pe-1"><i class="fa fa-plus"></i> New Customer</a>
                            </label>
                            <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select" id="customerSelect"></select>
                            <span asp-validation-for="CustomerId" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="GirlScoutId" class="form-label">Girl Scout</label>
                            <select asp-for="GirlScoutId" asp-items="Model.GirlScouts" class="form-select"></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="PaymentMethod" class="form-label">Payment Method</label>
                            <select asp-for="PaymentMethod" asp-items="Model.PaymentMethods" class="form-select" id="paymentMethod"></select>
                            <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="OrderedAt" class="form-label">Order Date</label>
                            <input asp-for="OrderedAt" type="date" class="form-control" />
                            <span asp-validation-for="OrderedAt" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3" id="deliveryDateGroup">
                            <label asp-for="DeliveryDate" class="form-label">Delivery Date</label>
                            <input asp-for="DeliveryDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label asp-for="Notes" class="form-label">Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="1"></textarea>
                        </div>
                    </div>

                    <!-- ═══════════ PRODUCT CARD SELECTION ═══════════ -->
                    <h5 class="card-title mt-4 mb-2">Select Products</h5>
                    <p class="text-muted small mb-3">Tap a product to add it to the order. Adjust the quantity using the +/- controls.</p>
                    <div class="row g-2 mb-3" id="orderProductCardGrid">
                        @foreach (var card in Model.ProductCards)
                        {
                            var imgSrc = !string.IsNullOrEmpty(card.ImagePath) ? card.ImagePath : "/images/pre.gif";
                            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                                <div class="card order-product-card h-100 text-center border"
                                     data-product-id="@card.Id"
                                     data-product-name="@card.Name"
                                     data-price="@card.PricePerBox"
                                     style="cursor:pointer; transition: all 0.15s ease; opacity:0.6">
                                    <div class="card-body p-2">
                                        <img src="@imgSrc" alt="@card.Name" class="mb-1 rounded" style="width:64px; height:64px; object-fit:contain;" />
                                        <p class="mb-0 fw-bold small" style="line-height:1.2">@card.Name</p>
                                        <small class="text-success fw-bold">@card.PricePerBox.ToString("C")</small>
                                        <!-- Qty controls (shown when selected) -->
                                        <div class="qty-controls d-none mt-1">
                                            <div class="d-flex align-items-center justify-content-center gap-1">
                                                <button type="button" class="btn btn-outline-danger btn-xs card-qty-minus" style="width:28px;height:28px;padding:0">
                                                    <i class="fa fa-minus" style="font-size:0.7rem"></i>
                                                </button>
                                                <input type="number" class="form-control form-control-sm text-center card-qty-input" value="1" min="1" style="width:44px;height:28px;padding:2px" />
                                                <button type="button" class="btn btn-outline-success btn-xs card-qty-plus" style="width:28px;height:28px;padding:0">
                                                    <i class="fa fa-plus" style="font-size:0.7rem"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Hidden line items container (populated by JS on submit) -->
                    <div id="lineItemsContainer" style="display:none"></div>

                    <!-- ═══════════ ORDER TOTAL SUMMARY ═══════════ -->
                    <div class="card bg-light mt-3 mb-3" id="orderTotalCard">
                        <div class="card-body py-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-muted">Total Boxes:</span>
                                    <strong id="createTotalBoxes" class="ms-1">0</strong>
                                    <span class="text-muted ms-3">Items:</span>
                                    <strong id="createTotalItems" class="ms-1">0</strong>
                                </div>
                                <div>
                                    <span class="text-muted">Order Total:</span>
                                    <strong id="createOrderTotal" class="ms-1 fs-4 text-primary">$0.00</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Save Order</button>
                        <a class="btn btn-outline-light ms-2" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ NEW CUSTOMER MODAL ═══════════ -->
<div class="modal fade" id="newCustomerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">New Customer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="custModalError" class="text-danger mb-2 d-none"></div>
                <div class="mb-3">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <input id="custName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input id="custEmail" type="email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <input id="custPhone" class="form-control" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="custSaveBtn">
                    <i class="fa fa-save me-1"></i> Save Customer
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            'use strict';

            var csrfToken = document.querySelector('meta[name="csrf-token"]').content;
            var orderTypeSelect = document.getElementById('orderType');
            var cardGrid = document.getElementById('orderProductCardGrid');

            // ── Product card selection ──
            cardGrid.addEventListener('click', function (e) {
                if (e.target.tagName === 'INPUT') return;

                var card = e.target.closest('.order-product-card');
                if (!card) return;

                var btn = e.target.closest('.card-qty-minus') || e.target.closest('.card-qty-plus');
                if (btn) {
                    // +/- button clicks
                    var input = card.querySelector('.card-qty-input');
                    var val = parseInt(input.value) || 1;
                    if (e.target.closest('.card-qty-plus')) {
                        input.value = val + 1;
                    } else {
                        if (val <= 1) {
                            // Deselect card
                            card.querySelector('.qty-controls').classList.add('d-none');
                            card.style.opacity = '0.6';
                            card.style.borderColor = '';
                            card.style.boxShadow = '';
                            input.value = 1;
                        } else {
                            input.value = val - 1;
                        }
                    }
                    recalcOrderTotal();
                    return;
                }

                // Toggle card selection
                var controls = card.querySelector('.qty-controls');
                var isSelected = !controls.classList.contains('d-none');

                if (isSelected) {
                    controls.classList.add('d-none');
                    card.style.opacity = '0.6';
                    card.style.borderColor = '';
                    card.style.boxShadow = '';
                    card.querySelector('.card-qty-input').value = 1;
                } else {
                    controls.classList.remove('d-none');
                    card.style.opacity = '1';
                    card.style.borderColor = '#0d6efd';
                    card.style.boxShadow = '0 0 0 2px rgba(13,110,253,.25)';
                }
                recalcOrderTotal();
            });

            cardGrid.addEventListener('input', function (e) {
                if (e.target.classList.contains('card-qty-input')) {
                    recalcOrderTotal();
                }
            });

            // ── Order total calculation ──
            function recalcOrderTotal() {
                var cards = document.querySelectorAll('.order-product-card');
                var totalBoxes = 0, totalPrice = 0, itemCount = 0;

                cards.forEach(function (card) {
                    var controls = card.querySelector('.qty-controls');
                    if (controls.classList.contains('d-none')) return;
                    var qty = parseInt(card.querySelector('.card-qty-input').value) || 0;
                    var price = parseFloat(card.dataset.price) || 0;
                    if (qty > 0) {
                        totalBoxes += qty;
                        totalPrice += qty * price;
                        itemCount++;
                    }
                });

                document.getElementById('createOrderTotal').textContent = '$' + totalPrice.toFixed(2);
                document.getElementById('createTotalBoxes').textContent = totalBoxes;
                document.getElementById('createTotalItems').textContent = itemCount;

                var totalCard = document.getElementById('orderTotalCard');
                totalCard.style.borderLeft = totalPrice > 0 ? '4px solid var(--primary)' : '';
            }

            // ── Build hidden line items on submit ──
            document.querySelector('form[action*="Create"]').addEventListener('submit', function () {
                var container = document.getElementById('lineItemsContainer');
                container.innerHTML = '';
                var idx = 0;
                var invSource = orderTypeSelect.value === 'Booth Sale' ? 'Troop' : 'Personal';

                document.querySelectorAll('.order-product-card').forEach(function (card) {
                    var controls = card.querySelector('.qty-controls');
                    if (controls.classList.contains('d-none')) return;
                    var qty = parseInt(card.querySelector('.card-qty-input').value) || 0;
                    if (qty <= 0) return;

                    var productId = card.dataset.productId;
                    var price = card.dataset.price;

                    container.innerHTML += '<input type="hidden" name="LineItems[' + idx + '].ProductId" value="' + productId + '">'
                        + '<input type="hidden" name="LineItems[' + idx + '].QuantityBoxes" value="' + qty + '">'
                        + '<input type="hidden" name="LineItems[' + idx + '].UnitPrice" value="' + price + '">'
                        + '<input type="hidden" name="LineItems[' + idx + '].InventorySource" value="' + invSource + '">';
                    idx++;
                });
            });

            // ── Show/hide delivery date based on order type ──
            function toggleDeliveryDate() {
                var ddGroup = document.getElementById('deliveryDateGroup');
                if (ddGroup) ddGroup.style.display = orderTypeSelect.value === 'Online Delivery' ? '' : 'none';
            }
            orderTypeSelect.addEventListener('change', toggleDeliveryDate);
            toggleDeliveryDate();

            // ── New Customer modal ──
            document.getElementById('openNewCustomerModal').addEventListener('click', function () {
                document.getElementById('custName').value = '';
                document.getElementById('custEmail').value = '';
                document.getElementById('custPhone').value = '';
                document.getElementById('custModalError').classList.add('d-none');
                bootstrap.Modal.getOrCreateInstance(document.getElementById('newCustomerModal')).show();
            });

            document.getElementById('custSaveBtn').addEventListener('click', function () {
                var name = document.getElementById('custName').value.trim();
                if (!name) {
                    document.getElementById('custModalError').textContent = 'Name is required.';
                    document.getElementById('custModalError').classList.remove('d-none');
                    return;
                }
                fetch('@Url.Action("QuickCreate", "Customers")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                    body: JSON.stringify({
                        name: name,
                        email: document.getElementById('custEmail').value.trim() || null,
                        phone: document.getElementById('custPhone').value.trim() || null
                    })
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.success) {
                        var sel = document.getElementById('customerSelect');
                        var opt = document.createElement('option');
                        opt.value = data.id;
                        opt.text = data.name;
                        sel.appendChild(opt);
                        sel.value = data.id;
                        bootstrap.Modal.getInstance(document.getElementById('newCustomerModal')).hide();
                    } else {
                        document.getElementById('custModalError').textContent = data.error || 'Failed to create.';
                        document.getElementById('custModalError').classList.remove('d-none');
                    }
                });
            });

            recalcOrderTotal();
        })();
    </script>
}
