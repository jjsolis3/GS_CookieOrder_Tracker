@model GS_CookieOrder_Tracker.Models.OrderCreateViewModel

@{
    ViewData["Title"] = "New Order";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">New Order</h4>
            </div>
            <div class="card-body">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="OrderType" class="form-label">Order Type</label>
                            <select asp-for="OrderType" asp-items="Model.OrderTypes" class="form-select" id="orderType"></select>
                            <span asp-validation-for="OrderType" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="CustomerId" class="form-label">Customer</label>
                            <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select"></select>
                            <span asp-validation-for="CustomerId" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="GirlScoutId" class="form-label">Girl Scout</label>
                            <select asp-for="GirlScoutId" asp-items="Model.GirlScouts" class="form-select"></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="PaymentMethod" class="form-label">Payment Method</label>
                            <select asp-for="PaymentMethod" asp-items="Model.PaymentMethods" class="form-select" id="paymentMethod"></select>
                            <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="OrderedAt" class="form-label">Order Date</label>
                            <input asp-for="OrderedAt" type="date" class="form-control" />
                            <span asp-validation-for="OrderedAt" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3" id="deliveryDateGroup">
                            <label asp-for="DeliveryDate" class="form-label">Delivery Date</label>
                            <input asp-for="DeliveryDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label asp-for="Notes" class="form-label">Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="1"></textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
                        <h5 class="card-title mb-0">Line Items</h5>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="addLineBtn">
                            <i class="fa fa-plus me-1"></i> Add Product
                        </button>
                    </div>
                    <hr>

                    <div id="lineItemsContainer">
                        @for (var i = 0; i < Model.LineItems.Count; i++)
                        {
                            <div class="row line-item align-items-end mb-2" data-index="@i">
                                <div class="col-md-4 mb-2">
                                    <label class="form-label">Product</label>
                                    <select name="LineItems[@i].ProductId" class="form-select product-select">
                                        <option value="">-- select --</option>
                                        @foreach (var p in Model.Products)
                                        {
                                            var price = Model.ProductPrices.GetValueOrDefault(p.Value, 0);
                                            if (p.Value == Model.LineItems[i].ProductId.ToString())
                                            {
                                                <option value="@p.Value" data-price="@price" selected="selected">@p.Text</option>
                                            }
                                            else
                                            {
                                                <option value="@p.Value" data-price="@price">@p.Text</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2 mb-2">
                                    <label class="form-label">Boxes</label>
                                    <input name="LineItems[@i].QuantityBoxes" type="number" min="1" value="@Model.LineItems[i].QuantityBoxes" class="form-control" />
                                </div>
                                <div class="col-md-2 mb-2">
                                    <label class="form-label">Unit Price</label>
                                    <input name="LineItems[@i].UnitPrice" type="number" step="0.01" min="0.01" value="@Model.LineItems[i].UnitPrice" class="form-control" readonly />
                                </div>
                                <div class="col-md-2 mb-2 inv-source-col">
                                    <label class="form-label">Inv. Source</label>
                                    <select name="LineItems[@i].InventorySource" class="form-select inv-source-select">
                                        @foreach (var s in Model.InventorySources)
                                        {
                                            <option value="@s.Value" selected="@(s.Value == Model.LineItems[i].InventorySource)">@s.Text</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2 mb-2">
                                    <button type="button" class="btn btn-outline-danger btn-sm remove-line-btn w-100">
                                        <i class="fa fa-trash"></i> Remove
                                    </button>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Save Order</button>
                        <a class="btn btn-outline-light ms-2" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Cache product options HTML from the first row for reuse
        var productOptionsHtml = document.querySelector('.line-item .product-select').innerHTML;
        var invSourceOptionsHtml = document.querySelector('.inv-source-select') ? document.querySelector('.inv-source-select').innerHTML : '<option value="Personal">Personal</option><option value="Troop">Troop</option>';

        // Auto-fill unit price when a product is selected
        function onProductChange(selectEl) {
            var opt = selectEl.options[selectEl.selectedIndex];
            var price = opt && opt.dataset.price ? opt.dataset.price : '0';
            var row = selectEl.closest('.line-item');
            var priceInput = row.querySelector('input[name$=".UnitPrice"]');
            if (priceInput) priceInput.value = price;
        }

        // Listen for product changes on all current and future rows (event delegation)
        document.getElementById('lineItemsContainer').addEventListener('change', function (e) {
            if (e.target.classList.contains('product-select')) {
                onProductChange(e.target);
            }
        });

        document.getElementById('addLineBtn').addEventListener('click', function () {
            var container = document.getElementById('lineItemsContainer');
            var idx = container.querySelectorAll('.line-item').length;
            var div = document.createElement('div');
            div.className = 'row line-item align-items-end mb-2';
            div.setAttribute('data-index', idx);
            div.innerHTML =
                '<div class="col-md-4 mb-2"><label class="form-label">Product</label>' +
                '<select name="LineItems[' + idx + '].ProductId" class="form-select product-select">' + productOptionsHtml + '</select></div>' +
                '<div class="col-md-2 mb-2"><label class="form-label">Boxes</label>' +
                '<input name="LineItems[' + idx + '].QuantityBoxes" type="number" min="1" value="1" class="form-control" /></div>' +
                '<div class="col-md-2 mb-2"><label class="form-label">Unit Price</label>' +
                '<input name="LineItems[' + idx + '].UnitPrice" type="number" step="0.01" min="0.01" value="0" class="form-control" readonly /></div>' +
                '<div class="col-md-2 mb-2 inv-source-col"><label class="form-label">Inv. Source</label>' +
                '<select name="LineItems[' + idx + '].InventorySource" class="form-select inv-source-select">' + invSourceOptionsHtml + '</select></div>' +
                '<div class="col-md-2 mb-2"><button type="button" class="btn btn-outline-danger btn-sm remove-line-btn w-100"><i class="fa fa-trash"></i> Remove</button></div>';
            container.appendChild(div);
            toggleInvSourceVisibility();
        });

        document.addEventListener('click', function (e) {
            if (e.target.closest('.remove-line-btn')) {
                var row = e.target.closest('.line-item');
                row.remove();
                reindexLines();
            }
        });

        function reindexLines() {
            document.querySelectorAll('#lineItemsContainer .line-item').forEach(function (row, i) {
                row.setAttribute('data-index', i);
                row.querySelectorAll('[name]').forEach(function (el) {
                    el.name = el.name.replace(/LineItems\[\d+\]/, 'LineItems[' + i + ']');
                });
            });
        }

        // Show/hide inventory source and delivery date based on order type
        var orderTypeSelect = document.getElementById('orderType');
        function toggleInvSourceVisibility() {
            var type = orderTypeSelect.value;
            var show = type !== 'Booth Sale';
            document.querySelectorAll('.inv-source-col').forEach(function (col) {
                col.style.display = show ? '' : 'none';
            });
            var ddGroup = document.getElementById('deliveryDateGroup');
            if (ddGroup) ddGroup.style.display = type === 'Online Delivery' ? '' : 'none';
        }
        orderTypeSelect.addEventListener('change', toggleInvSourceVisibility);
        toggleInvSourceVisibility();
    </script>
}
