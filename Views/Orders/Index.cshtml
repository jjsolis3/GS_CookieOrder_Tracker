@model IEnumerable<GS_CookieOrder_Tracker.Data.Order>

@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Orders</h2>
    <a class="btn btn-primary" asp-action="Create">New Order</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Order Date</th>
            <th>Customer</th>
            <th>Girl Scout</th>
            <th>Status</th>
            <th>Total Qty</th>
            <th>Total Price</th>
            <th>Paid</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.OrderedAt.ToString("yyyy-MM-dd")</td>
                <td>@order.Customer?.Name</td>
                <td>@(order.GirlScout == null ? "Unassigned" : $"{order.GirlScout.FirstName} {order.GirlScout.LastName}")</td>
                <td>@order.Status</td>
                <td>@order.TotalQty</td>
                <td>@order.TotalPrice?.ToString("C")</td>
                <td>@order.PaidAmount?.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>
