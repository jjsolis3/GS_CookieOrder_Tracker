@model GS_CookieOrder_Tracker.Models.OrdersIndexViewModel

@{
    ViewData["Title"] = "Orders";
}

<!-- ═══════════ KPI CARDS ═══════════ -->
<div class="row">
    <div class="col-xl-3 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-primary mb-0">@Model.TotalOrders</h4>
                    <small class="text-muted">Total Orders</small>
                </div>
                <div class="icon-box bg-primary-light rounded-circle">
                    <i class="fa fa-file-alt text-primary" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-success mb-0">@Model.TotalBoxesSold</h4>
                    <small class="text-muted">Boxes Sold</small>
                </div>
                <div class="icon-box bg-success-light rounded-circle">
                    <i class="fa fa-box text-success" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-info mb-0">@Model.TotalRevenue.ToString("C")</h4>
                    <small class="text-muted">Total Revenue</small>
                </div>
                <div class="icon-box rounded-circle" style="background:rgba(54,153,255,.1)">
                    <i class="fa fa-dollar-sign text-info" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-warning mb-0">@Model.TotalCollected.ToString("C")</h4>
                    <small class="text-muted">Total Collected</small>
                </div>
                <div class="icon-box rounded-circle" style="background:rgba(248,185,64,.1)">
                    <i class="fa fa-hand-holding-usd text-warning" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ FILTERS ═══════════ -->
<div class="row mb-3">
    <div class="col-12">
        <div class="card">
            <div class="card-body py-2">
                <form method="get" class="row align-items-end g-2">
                    <div class="col-md-3 col-sm-6">
                        <label class="form-label small mb-1">Search</label>
                        <input type="text" name="search" value="@Model.SearchTerm" class="form-control form-control-sm" placeholder="Customer, Scout, Notes..." />
                    </div>
                    <div class="col-md-2 col-sm-6">
                        <label class="form-label small mb-1">Order Type</label>
                        <select name="orderType" class="form-select form-select-sm">
                            @foreach (var item in Model.OrderTypes)
                            {
                                if (item.Value == Model.OrderTypeFilter)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2 col-sm-6">
                        <label class="form-label small mb-1">Status</label>
                        <select name="status" class="form-select form-select-sm">
                            @foreach (var item in Model.Statuses)
                            {
                                if (item.Value == Model.StatusFilter)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2 col-sm-6">
                        <label class="form-label small mb-1">From Date</label>
                        <input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-2 col-sm-6">
                        <label class="form-label small mb-1">To Date</label>
                        <input type="date" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-1 col-sm-12">
                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <i class="fa fa-search"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ ORDERS TABLE ═══════════ -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">
                    Orders
                    @if (Model.TotalFilteredCount > 0)
                    {
                        <small class="text-muted ms-2">(@Model.TotalFilteredCount found)</small>
                    }
                </h4>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-success btn-sm d-none" id="batchPrintBtn">
                        <i class="fa fa-print me-1"></i> Print Selected (<span id="selectedCount">0</span>)
                    </button>
                    <a class="btn btn-primary btn-sm" asp-action="Create">
                        <i class="fa fa-plus me-1"></i> New Order
                    </a>
                </div>
            </div>
            <div class="card-body">
                @if (!Model.Orders.Any())
                {
                    <p class="text-muted text-center py-4">No orders found matching your criteria.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm" style="table-layout:fixed;width:100%">
                            <colgroup>
                                <col style="width:35px">  <!-- Checkbox -->
                                <col style="width:90px">  <!-- Date -->
                                <col style="width:100px"> <!-- Type -->
                                <col style="width:120px"> <!-- Customer -->
                                <col style="width:100px"> <!-- Girl Scout -->
                                <col style="width:120px"> <!-- Status -->
                                <col style="width:55px">  <!-- Qty -->
                                <col style="width:80px">  <!-- Total -->
                                <col style="width:80px">  <!-- Paid -->
                                <col style="width:90px">  <!-- Actions -->
                            </colgroup>
                            <thead>
                                <tr>
                                    <th><input type="checkbox" id="selectAllOrders" class="form-check-input" title="Select All" /></th>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Customer</th>
                                    <th>Girl Scout</th>
                                    <th>Status</th>
                                    <th>Qty</th>
                                    <th>Total</th>
                                    <th>Paid</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.Orders)
                                {
                                    var typeClass = order.OrderType switch
                                    {
                                        "Direct Sale" => "badge-primary",
                                        "Online Delivery" => "badge-info",
                                        "Booth Sale" => "badge-success",
                                        _ => "badge-secondary"
                                    };
                                    var canPrint = order.OrderType != "Booth Sale";
                                    <tr data-order-id="@order.Id">
                                        <td>
                                            @if (canPrint)
                                            {
                                                <input type="checkbox" class="form-check-input order-select-cb" data-order-id="@order.Id" />
                                            }
                                        </td>
                                        <td class="text-nowrap">@order.OrderedAt.ToString("yyyy-MM-dd")</td>
                                        <td><span class="badge light @typeClass" style="font-size:.7rem">@order.OrderType</span></td>
                                        <td style="white-space:normal;word-break:break-word">@(order.Customer?.Name ?? "-")</td>
                                        <td style="white-space:normal;word-break:break-word">@(order.GirlScout == null ? "—" : $"{order.GirlScout.FirstName} {order.GirlScout.LastName}")</td>
                                        <td>
                                            <select class="form-select form-select-sm status-select" data-order-id="@order.Id" style="width:110px;font-size:.75rem;padding:2px 4px">
                                                @{
                                                    var statuses = new[] { "Pending", "Confirmed", "Paid", "Delivered", "Completed", "Cancelled" };
                                                }
                                                @foreach (var s in statuses)
                                                {
                                                    if (s == order.Status)
                                                    {
                                                        <option value="@s" selected="selected">@s</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@s">@s</option>
                                                    }
                                                }
                                            </select>
                                        </td>
                                        <td class="text-center">@order.TotalQty</td>
                                        <td class="text-nowrap">@order.TotalPrice?.ToString("C")</td>
                                        <td class="text-nowrap">@order.PaidAmount?.ToString("C")</td>
                                        <td class="text-nowrap">
                                            <button type="button" class="btn btn-xs btn-outline-primary detail-btn" data-order-id="@order.Id" title="View Details">
                                                <i class="fa fa-eye"></i>
                                            </button>
                                            @if (order.OrderType != "Booth Sale")
                                            {
                                                <a href="@Url.Action("Receipt", "Orders", new { id = order.Id })" target="_blank" class="btn btn-xs btn-outline-success ms-1" title="Print Receipt">
                                                    <i class="fa fa-print"></i>
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-3">
                            <ul class="pagination pagination-sm justify-content-center mb-0">
                                @{
                                    var queryParams = new Dictionary<string, string?>
                                    {
                                        { "search", Model.SearchTerm },
                                        { "orderType", Model.OrderTypeFilter },
                                        { "status", Model.StatusFilter },
                                        { "dateFrom", Model.DateFrom?.ToString("yyyy-MM-dd") },
                                        { "dateTo", Model.DateTo?.ToString("yyyy-MM-dd") },
                                        { "pageSize", Model.PageSize.ToString() }
                                    };
                                }

                                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" asp-action="Index" asp-all-route-data="@(new Dictionary<string, string?>(queryParams) { ["page"] = "1" })">
                                        <i class="fa fa-angle-double-left"></i>
                                    </a>
                                </li>
                                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" asp-action="Index" asp-all-route-data="@(new Dictionary<string, string?>(queryParams) { ["page"] = (Model.CurrentPage - 1).ToString() })">
                                        <i class="fa fa-angle-left"></i>
                                    </a>
                                </li>

                                @{
                                    var startPage = Math.Max(1, Model.CurrentPage - 2);
                                    var endPage = Math.Min(Model.TotalPages, startPage + 4);
                                    if (endPage - startPage < 4) startPage = Math.Max(1, endPage - 4);
                                }

                                @for (var p = startPage; p <= endPage; p++)
                                {
                                    <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" asp-action="Index" asp-all-route-data="@(new Dictionary<string, string?>(queryParams) { ["page"] = p.ToString() })">@p</a>
                                    </li>
                                }

                                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" asp-action="Index" asp-all-route-data="@(new Dictionary<string, string?>(queryParams) { ["page"] = (Model.CurrentPage + 1).ToString() })">
                                        <i class="fa fa-angle-right"></i>
                                    </a>
                                </li>
                                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" asp-action="Index" asp-all-route-data="@(new Dictionary<string, string?>(queryParams) { ["page"] = Model.TotalPages.ToString() })">
                                        <i class="fa fa-angle-double-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ ORDER DETAIL / EDIT MODAL ═══════════ -->
<div class="modal fade" id="orderDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Order Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="mdlCompletedAlert" class="alert alert-warning d-none">
                    <i class="fa fa-lock me-1"></i> This order is <strong>Completed</strong>. Change status to edit.
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Customer</label>
                        <p id="mdlCustomer" class="mb-0"></p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Girl Scout</label>
                        <p id="mdlGirlScout" class="mb-0"></p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Order Date</label>
                        <p id="mdlOrderDate" class="mb-0"></p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Order Type</label>
                        <p id="mdlOrderType" class="mb-0"></p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Status</label>
                        <select id="mdlStatus" class="form-select form-select-sm" style="width:160px">
                            <option value="Pending">Pending</option>
                            <option value="Confirmed">Confirmed</option>
                            <option value="Paid">Paid</option>
                            <option value="Delivered">Delivered</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Payment Method</label>
                        <select id="mdlPaymentMethod" class="form-select form-select-sm" style="width:160px">
                            <option value="Cash">Cash</option>
                            <option value="Credit Card">Credit Card</option>
                            <option value="Venmo">Venmo</option>
                            <option value="Zelle">Zelle</option>
                            <option value="Check">Check</option>
                            <option value="Online Payment">Online Payment</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-8">
                        <label class="form-label fw-bold">Notes</label>
                        <input id="mdlNotes" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-2 text-end">
                        <label class="form-label fw-bold">Total</label>
                        <p id="mdlTotalPrice" class="mb-0 fs-5 fw-bold text-primary"></p>
                    </div>
                    <div class="col-md-2 text-end">
                        <label class="form-label fw-bold">Paid</label>
                        <p id="mdlPaidAmount" class="mb-0 fs-5"></p>
                    </div>
                </div>

                <hr>

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0">Line Items</h6>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="mdlAddLineBtn">
                        <i class="fa fa-plus me-1"></i> Add Product
                    </button>
                </div>
                <table class="table table-sm" id="mdlLineItemsTable">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Qty</th>
                            <th>Unit Price</th>
                            <th>Source</th>
                            <th>Line Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="mdlLineItemsBody"></tbody>
                </table>

                <div id="mdlAddLineRow" class="row align-items-end mb-2 d-none">
                    <div class="col-md-4">
                        <label class="form-label">Product</label>
                        <select id="mdlNewProductId" class="form-select form-select-sm"></select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Qty</label>
                        <input id="mdlNewQty" type="number" min="1" value="1" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Source</label>
                        <select id="mdlNewSource" class="form-select form-select-sm">
                            <option value="Personal">Personal</option>
                            <option value="Troop">Troop</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-sm btn-success" id="mdlConfirmAddLine">
                            <i class="fa fa-check"></i> Add
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="mdlCancelAddLine">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <a href="#" target="_blank" class="btn btn-outline-success me-auto d-none" id="mdlPrintBtn">
                    <i class="fa fa-print me-1"></i> Print Receipt
                </a>
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="mdlSaveBtn">
                    <i class="fa fa-save me-1"></i> Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var csrfToken = document.querySelector('meta[name="csrf-token"]').content;
        var currentOrderId = null;
        var currentOrderData = null;

        // ══════════ BATCH SELECTION & PRINT ══════════
        var selectedOrders = new Set();
        var batchPrintBtn = document.getElementById('batchPrintBtn');
        var selectedCountEl = document.getElementById('selectedCount');
        var selectAllCb = document.getElementById('selectAllOrders');

        function updateBatchPrintButton() {
            var count = selectedOrders.size;
            if (selectedCountEl) selectedCountEl.textContent = count;
            if (batchPrintBtn) {
                if (count > 0) {
                    batchPrintBtn.classList.remove('d-none');
                } else {
                    batchPrintBtn.classList.add('d-none');
                }
            }
        }

        // Individual checkbox change
        document.querySelectorAll('.order-select-cb').forEach(function(cb) {
            cb.addEventListener('change', function() {
                var orderId = this.dataset.orderId;
                if (this.checked) {
                    selectedOrders.add(orderId);
                } else {
                    selectedOrders.delete(orderId);
                }
                updateBatchPrintButton();
                // Update "select all" checkbox state
                var allCbs = document.querySelectorAll('.order-select-cb');
                var allChecked = Array.from(allCbs).every(function(c) { return c.checked; });
                if (selectAllCb) selectAllCb.checked = allChecked;
            });
        });

        // Select all checkbox
        if (selectAllCb) {
            selectAllCb.addEventListener('change', function() {
                var allCbs = document.querySelectorAll('.order-select-cb');
                allCbs.forEach(function(cb) {
                    cb.checked = selectAllCb.checked;
                    var orderId = cb.dataset.orderId;
                    if (selectAllCb.checked) {
                        selectedOrders.add(orderId);
                    } else {
                        selectedOrders.delete(orderId);
                    }
                });
                updateBatchPrintButton();
            });
        }

        // Batch print button click
        if (batchPrintBtn) {
            batchPrintBtn.addEventListener('click', function() {
                if (selectedOrders.size === 0) {
                    alert('Please select at least one order to print.');
                    return;
                }
                var ids = Array.from(selectedOrders).join(',');
                var url = '@Url.Action("BatchReceipt", "Orders")' + '?ids=' + encodeURIComponent(ids);
                window.open(url, '_blank');
            });
        }

        // ── Quick status change from table ──
        document.querySelectorAll('.status-select').forEach(function (sel) {
            sel.addEventListener('change', function () {
                var orderId = this.dataset.orderId;
                var newStatus = this.value;
                fetch('@Url.Action("UpdateStatus", "Orders")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                    body: JSON.stringify({ orderId: orderId, status: newStatus })
                }).then(function (r) {
                    if (!r.ok) { alert('Failed to update status.'); location.reload(); }
                });
            });
        });

        // ── Open detail modal ──
        document.querySelectorAll('.detail-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                currentOrderId = this.dataset.orderId;
                loadOrderDetail(currentOrderId);
            });
        });

        function loadOrderDetail(orderId) {
            fetch('@Url.Action("GetDetail", "Orders")?id=' + orderId)
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    currentOrderData = data;
                    populateModal(data);
                    var modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('orderDetailModal'));
                    modal.show();
                });
        }

        function populateModal(d) {
            var isCompleted = d.status === 'Completed';

            document.getElementById('mdlCustomer').textContent = d.customerName || '—';
            document.getElementById('mdlGirlScout').textContent = d.girlScoutName || 'Unassigned';
            document.getElementById('mdlOrderDate').textContent = d.orderedAt;
            document.getElementById('mdlOrderType').textContent = d.orderType;
            document.getElementById('mdlTotalPrice').textContent = '$' + (d.totalPrice || 0).toFixed(2);
            document.getElementById('mdlPaidAmount').textContent = '$' + (d.paidAmount || 0).toFixed(2);

            document.getElementById('mdlStatus').value = d.status || 'Pending';
            document.getElementById('mdlPaymentMethod').value = d.paymentMethod || 'Cash';
            document.getElementById('mdlNotes').value = d.notes || '';

            var alertEl = document.getElementById('mdlCompletedAlert');
            alertEl.classList.toggle('d-none', !isCompleted);
            document.getElementById('mdlPaymentMethod').disabled = isCompleted;
            document.getElementById('mdlNotes').disabled = isCompleted;
            document.getElementById('mdlAddLineBtn').disabled = isCompleted;
            document.getElementById('mdlSaveBtn').disabled = isCompleted;

            var tbody = document.getElementById('mdlLineItemsBody');
            tbody.innerHTML = '';
            d.lineItems.forEach(function (li) {
                var tr = document.createElement('tr');
                tr.innerHTML =
                    '<td>' + (li.productName || '—') + '</td>' +
                    '<td>' + li.quantityBoxes + '</td>' +
                    '<td>$' + li.unitPrice.toFixed(2) + '</td>' +
                    '<td>' + (li.inventorySource || '') + '</td>' +
                    '<td>$' + li.lineTotal.toFixed(2) + '</td>' +
                    '<td>' + (isCompleted ? '' : '<button class="btn btn-sm btn-outline-danger mdl-remove-line" data-line-id="' + li.id + '"><i class="fa fa-trash"></i></button>') + '</td>';
                tbody.appendChild(tr);
            });

            var prodSel = document.getElementById('mdlNewProductId');
            prodSel.innerHTML = '<option value="">-- select --</option>';
            d.products.forEach(function (p) {
                prodSel.innerHTML += '<option value="' + p.id + '">' + p.name + ' ($' + p.price.toFixed(2) + ')</option>';
            });

            document.getElementById('mdlAddLineRow').classList.add('d-none');

            // Show/hide print button based on order type (not for Booth Sales)
            var printBtn = document.getElementById('mdlPrintBtn');
            if (d.orderType !== 'Booth Sale') {
                printBtn.classList.remove('d-none');
                printBtn.href = '@Url.Action("Receipt", "Orders")' + '?id=' + d.id;
            } else {
                printBtn.classList.add('d-none');
            }
        }

        document.getElementById('mdlSaveBtn').addEventListener('click', function () {
            fetch('@Url.Action("UpdateOrder", "Orders")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                body: JSON.stringify({
                    orderId: currentOrderId,
                    status: document.getElementById('mdlStatus').value,
                    paymentMethod: document.getElementById('mdlPaymentMethod').value,
                    notes: document.getElementById('mdlNotes').value
                })
            }).then(function (r) {
                if (r.ok) location.reload();
                else r.json().then(function (d) { alert(d.error || 'Failed to save.'); });
            });
        });

        document.getElementById('mdlLineItemsBody').addEventListener('click', function (e) {
            var btn = e.target.closest('.mdl-remove-line');
            if (!btn) return;
            if (!confirm('Remove this line item?')) return;
            fetch('@Url.Action("RemoveLineItem", "Orders")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                body: JSON.stringify({ lineItemId: btn.dataset.lineId })
            }).then(function (r) {
                if (r.ok) loadOrderDetail(currentOrderId);
                else alert('Failed to remove.');
            });
        });

        document.getElementById('mdlAddLineBtn').addEventListener('click', function () {
            document.getElementById('mdlAddLineRow').classList.remove('d-none');
            document.getElementById('mdlNewQty').value = 1;
        });
        document.getElementById('mdlCancelAddLine').addEventListener('click', function () {
            document.getElementById('mdlAddLineRow').classList.add('d-none');
        });

        document.getElementById('mdlConfirmAddLine').addEventListener('click', function () {
            var productId = document.getElementById('mdlNewProductId').value;
            var qty = parseInt(document.getElementById('mdlNewQty').value) || 1;
            var source = document.getElementById('mdlNewSource').value;
            if (!productId) { alert('Select a product.'); return; }

            fetch('@Url.Action("AddLineItem", "Orders")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                body: JSON.stringify({ orderId: currentOrderId, productId: productId, quantityBoxes: qty, inventorySource: source })
            }).then(function (r) {
                if (r.ok) {
                    document.getElementById('mdlAddLineRow').classList.add('d-none');
                    loadOrderDetail(currentOrderId);
                }
                else r.json().then(function (d) { alert(d.error || 'Failed to add.'); });
            });
        });

        document.getElementById('mdlStatus').addEventListener('change', function () {
            var isCompleted = this.value === 'Completed';
            document.getElementById('mdlCompletedAlert').classList.toggle('d-none', !isCompleted);
            document.getElementById('mdlPaymentMethod').disabled = isCompleted;
            document.getElementById('mdlNotes').disabled = isCompleted;
            document.getElementById('mdlAddLineBtn').disabled = isCompleted;
        });
    </script>
}
