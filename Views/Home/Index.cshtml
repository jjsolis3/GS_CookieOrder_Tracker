@model GS_CookieOrder_Tracker.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<!-- Metric cards row 1: Inventory -->
<div class="row">
    <div class="col-xl-3 col-sm-6">
        <div class="card overflow-hidden">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h2 class="text-primary mb-0">@Model.TotalBoxesOnHand</h2>
                        <small class="text-muted">Boxes On Hand</small>
                    </div>
                    <div class="icon-box bg-primary-light rounded-circle">
                        <i class="fa fa-cubes text-primary" style="font-size:1.4rem"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card overflow-hidden">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h2 class="text-success mb-0">@Model.TotalBoxesReceived</h2>
                        <small class="text-muted">Boxes Received</small>
                    </div>
                    <div class="icon-box bg-success-light rounded-circle">
                        <i class="fa fa-truck text-success" style="font-size:1.4rem"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card overflow-hidden">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h2 class="text-info mb-0">@Model.TotalBoxesSold</h2>
                        <small class="text-muted">Boxes Sold</small>
                    </div>
                    <div class="icon-box rounded-circle" style="background:rgba(54,185,204,.1)">
                        <i class="fa fa-shopping-cart text-info" style="font-size:1.4rem"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card overflow-hidden">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h2 class="text-warning mb-0">@Model.ActiveProducts</h2>
                        <small class="text-muted">Active Products</small>
                    </div>
                    <div class="icon-box rounded-circle" style="background:rgba(248,185,64,.1)">
                        <i class="fa fa-cookie text-warning" style="font-size:1.4rem"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Metric cards row 2: Orders & Paybacks -->
<div class="row">
    <div class="col-xl-3 col-sm-6">
        <div class="card overflow-hidden">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h2 class="text-primary mb-0">@Model.TotalOrders</h2>
                        <small class="text-muted">Total Orders</small>
                    </div>
                    <div class="icon-box bg-primary-light rounded-circle">
                        <i class="fa fa-file-alt text-primary" style="font-size:1.4rem"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card overflow-hidden">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        @{
                            var pendingColor = Model.PendingOrders > 0 ? "text-danger" : "text-success";
                        }
                        <h2 class="@pendingColor mb-0">@Model.PendingOrders</h2>
                        <small class="text-muted">Pending Orders</small>
                    </div>
                    <div class="icon-box rounded-circle" style="background:rgba(255,94,94,.1)">
                        <i class="fa fa-clock text-danger" style="font-size:1.4rem"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card overflow-hidden">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h2 class="text-success mb-0">@Model.TotalRevenue.ToString("C")</h2>
                        <small class="text-muted">Total Revenue</small>
                    </div>
                    <div class="icon-box bg-success-light rounded-circle">
                        <i class="fa fa-dollar-sign text-success" style="font-size:1.4rem"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card overflow-hidden">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        @{
                            var balColor = Model.RemainingBalance > 0 ? "text-warning" : "text-success";
                        }
                        <h2 class="@balColor mb-0">@Model.RemainingBalance.ToString("C")</h2>
                        <small class="text-muted">Payback Remaining</small>
                    </div>
                    <div class="icon-box rounded-circle" style="background:rgba(248,185,64,.1)">
                        <i class="fa fa-balance-scale text-warning" style="font-size:1.4rem"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Top Sellers & Recent Orders -->
<div class="row">
    <!-- Top 5 Sellers -->
    <div class="col-xl-5 col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Top Sellers</h4>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Product</th>
                                <th class="text-end">Boxes</th>
                                <th class="text-end">Revenue</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rank = 0; }
                            @foreach (var seller in Model.TopSellers)
                            {
                                rank++;
                                <tr>
                                    <td><span class="badge badge-primary">@rank</span></td>
                                    <td><strong>@seller.ProductName</strong></td>
                                    <td class="text-end">@seller.BoxesSold</td>
                                    <td class="text-end">@seller.Revenue.ToString("C")</td>
                                </tr>
                            }
                            @if (!Model.TopSellers.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">No sales recorded yet</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="col-xl-7 col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title">Recent Orders</h4>
                <a class="btn btn-primary btn-sm" asp-controller="Orders" asp-action="Create">
                    <i class="fa fa-plus me-1"></i> New Order
                </a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Customer</th>
                                <th>Type</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Total</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                var statusBadge = order.Status?.ToLower() switch
                                {
                                    "paid" => "badge-success",
                                    "delivered" => "badge-info",
                                    "pending" => "badge-warning",
                                    "cancelled" => "badge-danger",
                                    _ => "badge-primary"
                                };
                                var typeBadge = order.OrderType?.ToLower() switch
                                {
                                    "direct sale" => "badge-primary",
                                    "online delivery" => "badge-info",
                                    "booth sale" => "badge-warning",
                                    _ => "badge-secondary"
                                };
                                <tr>
                                    <td>@order.OrderedAt.ToString("MM/dd")</td>
                                    <td>@order.CustomerName</td>
                                    <td><span class="badge light @typeBadge">@order.OrderType</span></td>
                                    <td class="text-end">@order.TotalQty</td>
                                    <td class="text-end">@order.TotalPrice.ToString("C")</td>
                                    <td><span class="badge light @statusBadge">@order.Status</span></td>
                                    <td>
                                        <button type="button" class="btn btn-xs btn-outline-primary order-detail-btn" data-order-id="@order.OrderId" title="View Details">
                                            <i class="fa fa-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                            @if (!Model.RecentOrders.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted">No orders yet</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick actions -->
<div class="row">
    <div class="col-xl-4 col-sm-6">
        <div class="card">
            <div class="card-body text-center py-4">
                <i class="fa fa-plus-circle text-primary mb-3" style="font-size:2rem"></i>
                <h5>New Order</h5>
                <a class="btn btn-primary btn-sm" asp-controller="Orders" asp-action="Create">Create Order</a>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-sm-6">
        <div class="card">
            <div class="card-body text-center py-4">
                <i class="fa fa-truck text-success mb-3" style="font-size:2rem"></i>
                <h5>Log Receipt</h5>
                <a class="btn btn-success btn-sm" asp-controller="Inventory" asp-action="Create">New Receipt</a>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-sm-6">
        <div class="card">
            <div class="card-body text-center py-4">
                <i class="fa fa-money-bill-wave text-warning mb-3" style="font-size:2rem"></i>
                <h5>Record Payment</h5>
                <a class="btn btn-warning btn-sm" asp-controller="Paybacks" asp-action="Create">New Payback</a>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ ORDER DETAIL MODAL ═══════════ -->
<div class="modal fade" id="orderDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Order Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Customer</label>
                        <p id="mdlOrdCustomer" class="mb-0"></p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Girl Scout</label>
                        <p id="mdlOrdGirlScout" class="mb-0"></p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Order Date</label>
                        <p id="mdlOrdDate" class="mb-0"></p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Order Type</label>
                        <p id="mdlOrdType" class="mb-0"></p>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Status</label>
                        <p id="mdlOrdStatus" class="mb-0"></p>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Payment</label>
                        <p id="mdlOrdPayment" class="mb-0"></p>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Delivery Date</label>
                        <p id="mdlOrdDelivery" class="mb-0"></p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-12">
                        <label class="form-label fw-bold">Notes</label>
                        <p id="mdlOrdNotes" class="mb-0 text-muted"></p>
                    </div>
                </div>

                <hr>
                <h6 class="mb-2">Line Items</h6>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Line Total</th>
                            <th>Source</th>
                        </tr>
                    </thead>
                    <tbody id="mdlOrdLineItems"></tbody>
                    <tfoot>
                        <tr class="fw-bold">
                            <td>Total</td>
                            <td class="text-end" id="mdlOrdTotalQty"></td>
                            <td></td>
                            <td class="text-end" id="mdlOrdTotalPrice"></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Close</button>
                <a id="mdlOrdEditLink" class="btn btn-primary" href="#">
                    <i class="fa fa-pencil me-1"></i> Edit Order
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.order-detail-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var orderId = this.dataset.orderId;
                fetch('@Url.Action("GetDetail", "Orders")?id=' + orderId)
                    .then(function (r) { return r.json(); })
                    .then(function (d) {
                        document.getElementById('mdlOrdCustomer').textContent = d.customerName || 'N/A';
                        document.getElementById('mdlOrdGirlScout').textContent = d.girlScoutName || 'Unassigned';
                        document.getElementById('mdlOrdDate').textContent = d.orderedAt || '';
                        document.getElementById('mdlOrdType').textContent = d.orderType || '';
                        document.getElementById('mdlOrdStatus').textContent = d.status || '';
                        document.getElementById('mdlOrdPayment').textContent = d.paymentMethod || '';
                        document.getElementById('mdlOrdDelivery').textContent = d.deliveryDate || 'N/A';
                        document.getElementById('mdlOrdNotes').textContent = d.notes || 'None';

                        var tbody = document.getElementById('mdlOrdLineItems');
                        tbody.innerHTML = '';
                        var totalQty = 0;
                        var totalPrice = 0;
                        if (d.lineItems) {
                            d.lineItems.forEach(function (li) {
                                totalQty += li.quantityBoxes;
                                totalPrice += li.lineTotal;
                                var tr = document.createElement('tr');
                                tr.innerHTML =
                                    '<td>' + (li.productName || '') + '</td>' +
                                    '<td class="text-end">' + li.quantityBoxes + '</td>' +
                                    '<td class="text-end">$' + li.unitPrice.toFixed(2) + '</td>' +
                                    '<td class="text-end"><strong>$' + li.lineTotal.toFixed(2) + '</strong></td>' +
                                    '<td><span class="badge light ' + (li.inventorySource === 'Personal' ? 'badge-primary' : 'badge-secondary') + '">' + li.inventorySource + '</span></td>';
                                tbody.appendChild(tr);
                            });
                        }
                        document.getElementById('mdlOrdTotalQty').textContent = totalQty;
                        document.getElementById('mdlOrdTotalPrice').textContent = '$' + totalPrice.toFixed(2);

                        document.getElementById('mdlOrdEditLink').href = '@Url.Action("Edit", "Orders")/' + orderId;

                        var modalEl = document.getElementById('orderDetailModal');
                        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                        modal.show();
                    });
            });
        });
    </script>
}
