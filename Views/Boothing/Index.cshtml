@model GS_CookieOrder_Tracker.Models.BoothingViewModel

@{
    ViewData["Title"] = "Booth Sales";
}

<!-- ═══════════ DATE SELECTOR ═══════════ -->
<div class="row mb-3">
    <div class="col-auto">
        <form method="get" class="d-flex align-items-center gap-2">
            <label class="form-label mb-0 fw-bold">Booth Date:</label>
            <input type="date" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" class="form-control form-control-sm" style="width:170px" onchange="this.form.submit()" />
        </form>
    </div>
</div>

<!-- ═══════════ KPI CARDS ═══════════ -->
<div class="row">
    <div class="col-xl-4 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-primary mb-0">@Model.Orders.Count</h4>
                    <small class="text-muted">Sales Today</small>
                </div>
                <div class="icon-box bg-primary-light rounded-circle">
                    <i class="fa fa-receipt text-primary" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-success mb-0">@Model.TotalSales</h4>
                    <small class="text-muted">Boxes Sold</small>
                </div>
                <div class="icon-box bg-success-light rounded-circle">
                    <i class="fa fa-box text-success" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-info mb-0">@Model.TotalRevenue.ToString("C")</h4>
                    <small class="text-muted">Revenue</small>
                </div>
                <div class="icon-box rounded-circle" style="background:rgba(54,153,255,.1)">
                    <i class="fa fa-dollar-sign text-info" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ QUICK ADD FORM ═══════════ -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">New Booth Sale</h4>
            </div>
            <div class="card-body">
                <div id="boothLineItems">
                    <div class="row align-items-end mb-2 booth-line" data-index="0">
                        <div class="col-md-5">
                            <label class="form-label">Product</label>
                            <select class="form-select form-select-sm booth-product">
                                <option value="">-- select product --</option>
                                @foreach (var p in Model.Products)
                                {
                                    <option value="@p.Value" data-price="@Model.ProductPrices.GetValueOrDefault(p.Value, 0)">@p.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Qty</label>
                            <input type="number" min="1" value="1" class="form-control form-control-sm booth-qty" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Subtotal</label>
                            <input type="text" readonly class="form-control form-control-sm booth-subtotal" value="$0.00" />
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-sm btn-outline-danger booth-remove-line" style="margin-top:28px" disabled>
                                <i class="fa fa-times"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <button type="button" class="btn btn-sm btn-outline-primary mb-3" id="boothAddLine">
                    <i class="fa fa-plus me-1"></i> Add Product
                </button>
                <hr>
                <div class="row align-items-end">
                    <div class="col-md-3 mb-2">
                        <label class="form-label">Payment Method</label>
                        <select id="boothPayment" class="form-select form-select-sm">
                            @foreach (var pm in Model.PaymentMethods)
                            {
                                <option value="@pm.Value">@pm.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-2">
                        <label class="form-label">Notes (optional)</label>
                        <input id="boothNotes" class="form-control form-control-sm" placeholder="e.g. Booth location" />
                    </div>
                    <div class="col-md-2 mb-2">
                        <label class="form-label fw-bold">Total</label>
                        <p id="boothGrandTotal" class="mb-0 fs-5 fw-bold text-primary">$0.00</p>
                    </div>
                    <div class="col-md-3 mb-2">
                        <button type="button" class="btn btn-success w-100" id="boothSubmit">
                            <i class="fa fa-cash-register me-1"></i> Record Sale
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ TODAY'S SALES TABLE ═══════════ -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Sales for @Model.SelectedDate.ToString("MMM dd, yyyy")</h4>
            </div>
            <div class="card-body">
                @if (!Model.Orders.Any())
                {
                    <p class="text-muted text-center py-4">No booth sales recorded for this date.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Time</th>
                                    <th>Products</th>
                                    <th>Payment</th>
                                    <th>Boxes</th>
                                    <th>Total</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var counter = Model.Orders.Count; }
                                @foreach (var order in Model.Orders)
                                {
                                    <tr>
                                        <td>@counter</td>
                                        <td class="text-nowrap">@order.CreatedAt.ToString("hh:mm tt")</td>
                                        <td style="white-space:normal;word-break:break-word">
                                            <small>@string.Join(", ", order.LineItems.Select(li => $"{li.Product?.Name} x{li.QuantityBoxes}"))</small>
                                        </td>
                                        <td>@order.PaymentMethod</td>
                                        <td class="text-center">@order.TotalQty</td>
                                        <td class="text-nowrap">@order.TotalPrice?.ToString("C")</td>
                                        <td style="white-space:normal;word-break:break-word"><small>@order.Notes</small></td>
                                    </tr>
                                    counter--;
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var csrfToken = document.querySelector('meta[name="csrf-token"]').content;
        var selectedDate = '@Model.SelectedDate.ToString("yyyy-MM-dd")';

        // ── Product template HTML ──
        var productOptionsHtml = document.querySelector('.booth-product').innerHTML;

        // ── Calculate subtotals ──
        function recalc() {
            var total = 0;
            document.querySelectorAll('.booth-line').forEach(function (row) {
                var sel = row.querySelector('.booth-product');
                var qtyEl = row.querySelector('.booth-qty');
                var subEl = row.querySelector('.booth-subtotal');
                var opt = sel.options[sel.selectedIndex];
                var price = parseFloat(opt?.dataset?.price) || 0;
                var qty = parseInt(qtyEl.value) || 0;
                var sub = price * qty;
                subEl.value = '$' + sub.toFixed(2);
                total += sub;
            });
            document.getElementById('boothGrandTotal').textContent = '$' + total.toFixed(2);
        }

        document.getElementById('boothLineItems').addEventListener('change', recalc);
        document.getElementById('boothLineItems').addEventListener('input', recalc);

        // ── Add line ──
        document.getElementById('boothAddLine').addEventListener('click', function () {
            var container = document.getElementById('boothLineItems');
            var idx = container.querySelectorAll('.booth-line').length;
            var div = document.createElement('div');
            div.className = 'row align-items-end mb-2 booth-line';
            div.dataset.index = idx;
            div.innerHTML =
                '<div class="col-md-5"><select class="form-select form-select-sm booth-product">' + productOptionsHtml + '</select></div>' +
                '<div class="col-md-2"><input type="number" min="1" value="1" class="form-control form-control-sm booth-qty" /></div>' +
                '<div class="col-md-2"><input type="text" readonly class="form-control form-control-sm booth-subtotal" value="$0.00" /></div>' +
                '<div class="col-md-1"><button type="button" class="btn btn-sm btn-outline-danger booth-remove-line"><i class="fa fa-times"></i></button></div>';
            container.appendChild(div);
            // Enable remove on first row if more than one
            updateRemoveButtons();
        });

        // ── Remove line ──
        document.getElementById('boothLineItems').addEventListener('click', function (e) {
            var btn = e.target.closest('.booth-remove-line');
            if (!btn) return;
            btn.closest('.booth-line').remove();
            updateRemoveButtons();
            recalc();
        });

        function updateRemoveButtons() {
            var lines = document.querySelectorAll('.booth-line');
            lines.forEach(function (line) {
                line.querySelector('.booth-remove-line').disabled = lines.length <= 1;
            });
        }

        // ── Submit sale ──
        document.getElementById('boothSubmit').addEventListener('click', function () {
            var items = [];
            document.querySelectorAll('.booth-line').forEach(function (row) {
                var productId = row.querySelector('.booth-product').value;
                var qty = parseInt(row.querySelector('.booth-qty').value) || 0;
                if (productId && qty > 0) {
                    items.push({ productId: productId, qty: qty });
                }
            });

            if (items.length === 0) {
                alert('Add at least one product.');
                return;
            }

            fetch('@Url.Action("QuickAdd", "Boothing")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                body: JSON.stringify({
                    date: selectedDate,
                    paymentMethod: document.getElementById('boothPayment').value,
                    notes: document.getElementById('boothNotes').value || null,
                    items: items
                })
            }).then(function (r) {
                if (r.ok) location.reload();
                else r.json().then(function (d) { alert(d.error || 'Failed to record sale.'); });
            });
        });
    </script>
}
