@model GS_CookieOrder_Tracker.Models.BoothingViewModel

@{
    ViewData["Title"] = "Booth Sales";
    var hasSession = Model.ActiveSession != null;
}

<!-- ═══════════ SESSION SETUP (shown when no active session) ═══════════ -->
@if (!hasSession)
{
    <div class="row justify-content-center" id="sessionSetupPanel">
        <div class="col-lg-6 col-md-8 col-12">
            <div class="card">
                <div class="card-header text-center">
                    <h4 class="card-title mb-0">Start Booth Session</h4>
                </div>
                <div class="card-body">
                    <p class="text-muted text-center mb-3">
                        Set the location and number of scouts once. All sales during this session will be tracked together.
                    </p>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Booth Location</label>
                        <input id="sessionLocation" list="locationList" class="form-control" placeholder="e.g. Walmart on Main St" autofocus />
                        <datalist id="locationList">
                            @foreach (var loc in Model.RecentLocations)
                            {
                                <option value="@loc" />
                            }
                        </datalist>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Number of Girl Scouts</label>
                        <input type="number" id="sessionScoutCount" class="form-control" min="1" value="1" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Notes (optional)</label>
                        <input id="sessionNotes" class="form-control" placeholder="e.g. Troop 774 - Saturday shift" />
                    </div>

                    <!-- Starting Inventory (Troop-provided) -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="fa fa-boxes me-1"></i> Starting Inventory (Troop-Provided)
                        </label>
                        <p class="text-muted small mb-2">
                            Enter the number of boxes brought to the booth. This helps track what's sold vs. remaining.
                        </p>
                        <div id="inventoryInputs" class="border rounded p-2" style="max-height:250px; overflow-y:auto;">
                            @foreach (var card in Model.ProductCards)
                            {
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="@(string.IsNullOrEmpty(card.ImagePath) ? "/images/pre.gif" : card.ImagePath)"
                                             alt="@card.Name" style="width:32px;height:32px;object-fit:contain;border-radius:4px" />
                                        <span class="small">@card.Name</span>
                                    </div>
                                    <input type="number" min="0" value="0"
                                           class="form-control form-control-sm inventory-input"
                                           data-product-id="@card.Id"
                                           style="width:70px" />
                                </div>
                            }
                        </div>
                    </div>

                    <button type="button" class="btn btn-primary w-100 btn-lg" id="startSessionBtn">
                        <i class="fa fa-play me-2"></i> Start Booth Session
                    </button>
                </div>
            </div>
            <!-- Past sales date picker for viewing history when no active session -->
            @* <div class="card mt-3">
                <div class="card-body">
                    <form method="get" class="d-flex align-items-center gap-2 justify-content-center">
                        <label class="form-label mb-0 fw-bold">View Past Sales:</label>
                        <input type="date" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" class="form-control form-control-sm" style="width:170px" onchange="this.form.submit()" />
                    </form>
                </div>
            </div> *@
        </div>
    </div>
}

<!-- ═══════════ ACTIVE SESSION BAR ═══════════ -->
@if (hasSession)
{
    <div class="card mb-3 border-primary" id="sessionBar">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <span class="badge badge-primary" style="font-size:0.9rem">
                        <i class="fa fa-map-marker-alt me-1"></i> @Model.ActiveSession!.Location
                    </span>
                    <span class="text-muted">
                        <i class="fa fa-users me-1"></i> @Model.ActiveSession.ScoutCount Scout@(Model.ActiveSession.ScoutCount != 1 ? "s" : "")
                    </span>
                    <span class="text-muted">
                        <i class="fa fa-clock me-1"></i> Started <span id="sessionTimer" data-start="@Model.ActiveSession.StartedAt.ToString("o")"></span>
                    </span>
                </div>
                <div class="d-flex gap-2">
                    @{
                        var csvUrl = Model.ActiveSession != null
                            ? Url.Action("ExportCsv", new { sessionId = Model.ActiveSession.Id })
                            : Url.Action("ExportCsv", new { date = Model.SelectedDate.ToString("yyyy-MM-dd") });
                    }
                    <a href="@csvUrl" class="btn btn-outline-success btn-sm">
                        <i class="fa fa-file-csv me-1"></i> Export
                    </a>
                    @if (Model.ActiveSession != null)
                    {
                        <a href="@Url.Action("BoothReport", "Reports", new { sessionId = Model.ActiveSession.Id })" class="btn btn-outline-warning btn-sm" target="_blank">
                            <i class="fa fa-print me-1"></i> Print Report
                        </a>
                    }
                    <button type="button" class="btn btn-outline-danger btn-sm" id="endSessionBtn" data-session-id="@Model.ActiveSession!.Id">
                        <i class="fa fa-stop me-1"></i> End Session
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════ KPI CARDS ═══════════ -->
    <div class="row">
        <div class="col-4">
            <div class="card">
                <div class="card-body text-center py-2">
                    <h4 class="text-primary mb-0" id="kpiSaleCount">@Model.Sales.Count</h4>
                    <small class="text-muted">Sales</small>
                </div>
            </div>
        </div>
        <div class="col-4">
            <div class="card">
                <div class="card-body text-center py-2">
                    <h4 class="text-success mb-0" id="kpiBoxCount">@Model.TotalSales</h4>
                    <small class="text-muted">Boxes</small>
                </div>
            </div>
        </div>
        <div class="col-4">
            <div class="card">
                <div class="card-body text-center py-2">
                    <h4 class="text-info mb-0" id="kpiRevenue">@Model.TotalRevenue.ToString("C")</h4>
                    <small class="text-muted">Revenue</small>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════ BOOTH INVENTORY STATUS ═══════════ -->
    @if (Model.BoothInventoryItems.Any())
    {
        <div class="card mb-3" id="boothInventoryPanel">
            <div class="card-header py-2 d-flex justify-content-between align-items-center">
                <h6 class="mb-0">
                    <i class="fa fa-boxes me-1"></i> Booth Inventory (Troop Stock)
                </h6>
                <button type="button" class="btn btn-xs btn-outline-secondary" id="toggleInventoryBtn">
                    <i class="fa fa-chevron-up" id="inventoryToggleIcon"></i>
                </button>
            </div>
            <div class="card-body py-2" id="boothInventoryBody">
                <div class="row g-2" id="inventoryStatusGrid">
                    @foreach (var item in Model.BoothInventoryItems)
                    {
                        var percentUsed = item.StartingQuantity > 0
                            ? (int)((double)item.SoldQuantity / item.StartingQuantity * 100)
                            : 0;
                        var barColor = percentUsed >= 90 ? "bg-danger" : percentUsed >= 70 ? "bg-warning" : "bg-success";
                        var textColor = item.RemainingQuantity <= 0 ? "text-danger" : item.RemainingQuantity <= 5 ? "text-warning" : "text-success";
                        <div class="col-6 col-md-4 col-lg-3 inventory-status-item" data-product-id="@item.ProductId">
                            <div class="border rounded p-2 h-100">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <small class="fw-bold text-truncate" style="max-width:80%">@item.ProductName</small>
                                    <span class="badge @textColor inventory-remaining" style="font-size:0.8rem">@item.RemainingQuantity</span>
                                </div>
                                <div class="progress" style="height:6px">
                                    <div class="progress-bar @barColor inventory-progress"
                                         role="progressbar"
                                         style="width:@(100 - percentUsed)%"
                                         data-starting="@item.StartingQuantity"></div>
                                </div>
                                <div class="d-flex justify-content-between mt-1">
                                    <small class="text-muted">Sold: <span class="inventory-sold">@item.SoldQuantity</span></small>
                                    <small class="text-muted">of @item.StartingQuantity</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- ═══════════ PRODUCT CARD GRID ═══════════ -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center py-2 flex-wrap gap-2">
            <h5 class="card-title mb-0">Tap a Cookie to Sell</h5>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                @if (Model.Scouts.Any())
                {
                    <select id="boothScout" class="form-select form-select-sm" style="width:150px">
                        <option value="">-- Scout --</option>
                        @foreach (var sc in Model.Scouts)
                        {
                            <option value="@sc.Value">@sc.Text</option>
                        }
                    </select>
                }
                <select id="boothPayment" class="form-select form-select-sm" style="width:130px">
                    @foreach (var pm in Model.PaymentMethods)
                    {
                        <option value="@pm.Value">@pm.Text</option>
                    }
                </select>
            </div>
        </div>
        <div class="card-body pt-2 pb-3">
            <!-- Cart summary (hidden until items added) -->
            <div id="cartSummary" class="alert alert-primary d-none mb-3 py-2">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <strong id="cartItemCount">0</strong> item(s) &middot;
                        <strong id="cartBoxCount">0</strong> boxes &middot;
                        Total: <strong id="cartTotal" class="fs-5">$0.00</strong>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-light btn-sm" id="cartClearBtn">Clear</button>
                        <button type="button" class="btn btn-success" id="cartSubmitBtn">
                            <i class="fa fa-check me-1"></i> Submit Sale
                        </button>
                    </div>
                </div>
            </div>

            <!-- Product grid -->
            <div class="row g-2" id="productGrid">
                @foreach (var card in Model.ProductCards)
                {
                    var imgSrc = !string.IsNullOrEmpty(card.ImagePath)
                        ? card.ImagePath
                        : "/images/pre.gif";
                    <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                        <div class="card product-card h-100 text-center border"
                             data-product-id="@card.Id"
                             data-product-name="@card.Name"
                             data-price="@card.PricePerBox"
                             style="cursor:pointer; transition: all 0.15s ease;">
                            <div class="card-body p-2">
                                <img src="@imgSrc" alt="@card.Name" class="mb-1 rounded" style="width:70px; height:70px; object-fit:contain;" />
                                <p class="mb-0 fw-bold small" style="line-height:1.2">@card.Name</p>
                                <small class="text-success fw-bold">@card.PricePerBox.ToString("C")</small>
                                <!-- Quantity controls (shown when selected) -->
                                <div class="qty-controls d-none mt-1">
                                    <div class="d-flex align-items-center justify-content-center gap-1">
                                        <button type="button" class="btn btn-outline-danger btn-xs qty-minus" style="width:28px;height:28px;padding:0">
                                            <i class="fa fa-minus" style="font-size:0.7rem"></i>
                                        </button>
                                        <input type="number" class="form-control form-control-sm text-center qty-input" value="1" min="1" style="width:44px;height:28px;padding:2px" />
                                        <button type="button" class="btn btn-outline-success btn-xs qty-plus" style="width:28px;height:28px;padding:0">
                                            <i class="fa fa-plus" style="font-size:0.7rem"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ═══════════ SESSION SALES LOG ═══════════ -->
    <div class="card">
        <div class="card-header py-2">
            <h5 class="card-title mb-0">Session Sales</h5>
        </div>
        <div class="card-body">
            <div id="salesEmpty" class="text-muted text-center py-3 @(Model.Sales.Any() ? "d-none" : "")">No sales yet. Tap a cookie above to start selling!</div>
            <div class="table-responsive @(!Model.Sales.Any() ? "d-none" : "")" id="salesTableWrap">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th style="width:35px">#</th>
                            <th style="width:60px">Time</th>
                            <th>Products</th>
                            <th style="width:90px">Scout</th>
                            <th style="width:70px">Payment</th>
                            <th style="width:50px" class="text-center">Boxes</th>
                            <th style="width:70px" class="text-end">Total</th>
                            <th style="width:35px"></th>
                        </tr>
                    </thead>
                    <tbody id="salesTableBody">
                        @{ var counter = Model.Sales.Count; }
                        @foreach (var sale in Model.Sales)
                        {
                            <tr>
                                <td>@counter</td>
                                <td class="text-nowrap"><small>@sale.CreatedAt.ToString("h:mm tt")</small></td>
                                <td style="white-space:normal;word-break:break-word">
                                    <small>@string.Join(", ", sale.LineItems.Select(li => $"{li.ProductName} x{li.QuantityBoxes}"))</small>
                                </td>
                                <td><small>@(sale.ScoutName ?? "")</small></td>
                                <td><small>@sale.PaymentMethod</small></td>
                                <td class="text-center">@sale.TotalQty</td>
                                <td class="text-end text-nowrap"><strong>@sale.TotalPrice.ToString("C")</strong></td>
                                <td>
                                    <button type="button" class="btn btn-xs btn-outline-primary sale-edit-btn" data-sale-group-id="@sale.SaleGroupId" title="Edit">
                                        <i class="fa fa-pencil"></i>
                                    </button>
                                </td>
                            </tr>
                            counter--;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- ═══════════ EDIT SALE MODAL ═══════════ -->
<div class="modal fade" id="editSaleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Sale</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (Model.Scouts.Any())
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">Scout</label>
                        <select id="editScout" class="form-select form-select-sm">
                            <option value="">-- No Scout --</option>
                            @foreach (var sc in Model.Scouts)
                            {
                                <option value="@sc.Value">@sc.Text</option>
                            }
                        </select>
                    </div>
                }
                <div class="mb-3">
                    <label class="form-label fw-bold">Payment Method</label>
                    <select id="editPayMethod" class="form-select form-select-sm">
                        @foreach (var pm in Model.PaymentMethods)
                        {
                            <option value="@pm.Value">@pm.Text</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Notes</label>
                    <input type="text" id="editNotes" class="form-control form-control-sm" />
                </div>
                <h6 class="mb-2">Products</h6>
                <div id="editLineItems"></div>
                <div class="text-end mt-2">
                    <strong>Total: <span id="editTotal">$0.00</span></strong>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-danger me-auto" id="editDeleteBtn">
                    <i class="fa fa-trash me-1"></i> Delete
                </button>
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="editSaveBtn">
                    <i class="fa fa-save me-1"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .product-card.selected {
        border-color: #007bff !important;
        box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.5);
        background: rgba(0, 123, 255, 0.04);
    }
    .product-card:active {
        transform: scale(0.97);
    }
    .kpi-flash {
        animation: kpiPulse 0.5s ease;
    }
    @@keyframes kpiPulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.15); color: #28a745; }
        100% { transform: scale(1); }
    }
    @@media (max-width: 576px) {
        .product-card .card-body { padding: 6px !important; }
        .product-card img { width: 55px !important; height: 55px !important; }
        .product-card .fw-bold { font-size: 0.75rem !important; }
    }
</style>

@section Scripts {
    <script>
        // ══════════ BOOTH SALES JAVASCRIPT ══════════
        document.addEventListener('DOMContentLoaded', function() {
            console.log('[BoothSales] Script initialized');

            // Safe element access helpers
            function getEl(id) { return document.getElementById(id); }
            function getAll(sel) { return document.querySelectorAll(sel); }

            // CSRF token
            var csrfMeta = document.querySelector('meta[name="csrf-token"]');
            var csrfToken = csrfMeta ? csrfMeta.content : '';

            // Page state
            var selectedDate = '@Model.SelectedDate.ToString("yyyy-MM-dd")';
            var sessionId = '@(hasSession ? Model.ActiveSession!.Id.ToString() : "")';
            var currentSaleCount = parseInt('@Model.Sales.Count') || 0;
            var cart = {};

            console.log('[BoothSales] Session ID:', sessionId || '(none)');

            // ══════════ SESSION TIMER ══════════
            var timerEl = getEl('sessionTimer');
            if (timerEl && timerEl.dataset.start) {
                var startTime = new Date(timerEl.dataset.start);
                function updateTimer() {
                    var now = new Date();
                    var diff = Math.floor((now - startTime) / 1000);
                    var hrs = Math.floor(diff / 3600);
                    var mins = Math.floor((diff % 3600) / 60);
                    timerEl.textContent = (hrs > 0 ? hrs + 'h ' : '') + mins + 'm ago';
                }
                updateTimer();
                setInterval(updateTimer, 30000);
            }

            // ══════════ START SESSION ══════════
            var startBtn = getEl('startSessionBtn');
            if (startBtn) {
                console.log('[BoothSales] Start session button found');
                startBtn.onclick = function() {
                    var locEl = getEl('sessionLocation');
                    var loc = locEl ? locEl.value.trim() : '';
                    if (!loc) { alert('Please enter a booth location.'); return; }

                    var scoutCountEl = getEl('sessionScoutCount');
                    var notesEl = getEl('sessionNotes');

                    // Collect inventory inputs
                    var inventory = [];
                    getAll('.inventory-input').forEach(function(inp) {
                        var qty = parseInt(inp.value) || 0;
                        if (qty > 0) {
                            inventory.push({ productId: inp.dataset.productId, quantity: qty });
                        }
                    });

                    fetch('@Url.Action("StartSession", "Boothing")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                        body: JSON.stringify({
                            location: loc,
                            scoutCount: scoutCountEl ? (parseInt(scoutCountEl.value) || 1) : 1,
                            notes: notesEl ? (notesEl.value || null) : null,
                            inventory: inventory
                        })
                    }).then(function(r) {
                        if (r.ok) location.reload();
                        else r.json().then(function(d) { alert(d.error || 'Failed to start session.'); });
                    }).catch(function() { alert('Network error. Please try again.'); });
                };
            }

            // ══════════ END SESSION ══════════
            var endBtn = getEl('endSessionBtn');
            if (endBtn) {
                console.log('[BoothSales] End session button found, sessionId from data attr:', endBtn.dataset.sessionId);
                endBtn.onclick = function() {
                    console.log('[BoothSales] End session clicked');
                    if (!confirm('End this booth session? You can still view the sales from the history.')) return;

                    var sid = endBtn.dataset.sessionId;
                    console.log('[BoothSales] Ending session:', sid);

                    fetch('@Url.Action("EndSession", "Boothing")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                        body: JSON.stringify({ sessionId: sid })
                    }).then(function(r) {
                        console.log('[BoothSales] End session response:', r.status);
                        if (r.ok) location.reload();
                        else r.json().then(function(d) { alert(d.error || 'Failed to end session.'); });
                    }).catch(function(err) {
                        console.error('[BoothSales] End session error:', err);
                        alert('Network error. Please try again.');
                    });
                };
            }

            // ══════════ PRODUCT CARD CLICK HANDLING ══════════
            var productCards = getAll('.product-card');
            console.log('[BoothSales] Found', productCards.length, 'product cards');

            productCards.forEach(function(card) {
                // Main card click handler
                card.onclick = function(e) {
                    console.log('[BoothSales] Card clicked:', card.dataset.productName);

                    // Ignore clicks on buttons or input
                    if (e.target.closest('.qty-minus') || e.target.closest('.qty-plus') || e.target.classList.contains('qty-input')) {
                        return;
                    }

                    var pid = card.dataset.productId;
                    var qtyControls = card.querySelector('.qty-controls');
                    var qtyInput = card.querySelector('.qty-input');

                    if (card.classList.contains('selected')) {
                        // Deselect
                        card.classList.remove('selected');
                        if (qtyControls) qtyControls.classList.add('d-none');
                        delete cart[pid];
                        console.log('[BoothSales] Deselected:', card.dataset.productName);
                    } else {
                        // Select
                        card.classList.add('selected');
                        if (qtyControls) qtyControls.classList.remove('d-none');
                        if (qtyInput) qtyInput.value = 1;
                        cart[pid] = {
                            name: card.dataset.productName || '',
                            price: parseFloat(card.dataset.price) || 0,
                            qty: 1
                        };
                        console.log('[BoothSales] Selected:', card.dataset.productName);
                    }
                    updateCart();
                };

                // Qty minus button
                var minusBtn = card.querySelector('.qty-minus');
                if (minusBtn) {
                    minusBtn.onclick = function(e) {
                        e.stopPropagation();
                        var qtyInput = card.querySelector('.qty-input');
                        var pid = card.dataset.productId;
                        var val = parseInt(qtyInput.value) || 1;
                        val = Math.max(1, val - 1);
                        qtyInput.value = val;
                        if (cart[pid]) cart[pid].qty = val;
                        updateCart();
                    };
                }

                // Qty plus button
                var plusBtn = card.querySelector('.qty-plus');
                if (plusBtn) {
                    plusBtn.onclick = function(e) {
                        e.stopPropagation();
                        var qtyInput = card.querySelector('.qty-input');
                        var pid = card.dataset.productId;
                        var val = parseInt(qtyInput.value) || 1;
                        val = val + 1;
                        qtyInput.value = val;
                        if (cart[pid]) cart[pid].qty = val;
                        updateCart();
                    };
                }

                // Qty input change
                var qtyInput = card.querySelector('.qty-input');
                if (qtyInput) {
                    qtyInput.onclick = function(e) { e.stopPropagation(); };
                    qtyInput.onchange = function() {
                        var pid = card.dataset.productId;
                        var val = parseInt(qtyInput.value) || 1;
                        if (val < 1) { val = 1; qtyInput.value = 1; }
                        if (cart[pid]) cart[pid].qty = val;
                        updateCart();
                    };
                }
            });

            function updateCart() {
                var summary = getEl('cartSummary');
                var keys = Object.keys(cart);
                if (keys.length === 0) {
                    if (summary) summary.classList.add('d-none');
                    return;
                }
                if (summary) summary.classList.remove('d-none');

                var totalBoxes = 0, totalPrice = 0;
                keys.forEach(function(pid) {
                    totalBoxes += cart[pid].qty;
                    totalPrice += cart[pid].qty * cart[pid].price;
                });

                var itemCountEl = getEl('cartItemCount');
                var boxCountEl = getEl('cartBoxCount');
                var totalEl = getEl('cartTotal');
                if (itemCountEl) itemCountEl.textContent = keys.length;
                if (boxCountEl) boxCountEl.textContent = totalBoxes;
                if (totalEl) totalEl.textContent = '$' + totalPrice.toFixed(2);
            }

            var clearBtn = getEl('cartClearBtn');
            if (clearBtn) {
                clearBtn.onclick = function() {
                    cart = {};
                    getAll('.product-card.selected').forEach(function(c) {
                        c.classList.remove('selected');
                        var qc = c.querySelector('.qty-controls');
                        if (qc) qc.classList.add('d-none');
                    });
                    updateCart();
                };
            }

            // ══════════ KPI HELPERS ══════════
            function flashKpi(el) {
                if (!el) return;
                el.classList.remove('kpi-flash');
                void el.offsetWidth;
                el.classList.add('kpi-flash');
            }

            function updateKpis(kpi) {
                var saleEl = getEl('kpiSaleCount');
                var boxEl = getEl('kpiBoxCount');
                var revEl = getEl('kpiRevenue');
                if (saleEl) { saleEl.textContent = kpi.saleCount; flashKpi(saleEl); }
                if (boxEl) { boxEl.textContent = kpi.totalBoxes; flashKpi(boxEl); }
                if (revEl) { revEl.textContent = '$' + kpi.totalRevenue.toFixed(2); flashKpi(revEl); }
            }

            // ══════════ BOOTH INVENTORY UPDATES ══════════
            function updateBoothInventory(inventory) {
                if (!inventory || !inventory.length) return;

                inventory.forEach(function(item) {
                    var statusItem = document.querySelector('.inventory-status-item[data-product-id="' + item.productId + '"]');
                    if (!statusItem) return;

                    var remainingEl = statusItem.querySelector('.inventory-remaining');
                    var soldEl = statusItem.querySelector('.inventory-sold');
                    var progressEl = statusItem.querySelector('.inventory-progress');

                    if (remainingEl) {
                        remainingEl.textContent = item.remaining;
                        // Update color based on remaining
                        remainingEl.className = 'badge inventory-remaining';
                        if (item.remaining <= 0) remainingEl.classList.add('text-danger');
                        else if (item.remaining <= 5) remainingEl.classList.add('text-warning');
                        else remainingEl.classList.add('text-success');

                        // Flash animation
                        remainingEl.style.animation = 'none';
                        void remainingEl.offsetWidth;
                        remainingEl.style.animation = 'kpiPulse 0.5s ease';
                    }

                    if (soldEl) soldEl.textContent = item.sold;

                    if (progressEl) {
                        var starting = parseInt(progressEl.dataset.starting) || 1;
                        var percentRemaining = Math.max(0, (item.remaining / starting) * 100);
                        progressEl.style.width = percentRemaining + '%';

                        // Update bar color
                        progressEl.className = 'progress-bar inventory-progress';
                        var percentUsed = 100 - percentRemaining;
                        if (percentUsed >= 90) progressEl.classList.add('bg-danger');
                        else if (percentUsed >= 70) progressEl.classList.add('bg-warning');
                        else progressEl.classList.add('bg-success');
                    }
                });
            }

            // ══════════ INVENTORY PANEL TOGGLE ══════════
            var toggleBtn = getEl('toggleInventoryBtn');
            var inventoryBody = getEl('boothInventoryBody');
            var toggleIcon = getEl('inventoryToggleIcon');
            if (toggleBtn && inventoryBody) {
                toggleBtn.onclick = function() {
                    if (inventoryBody.style.display === 'none') {
                        inventoryBody.style.display = '';
                        if (toggleIcon) toggleIcon.className = 'fa fa-chevron-up';
                    } else {
                        inventoryBody.style.display = 'none';
                        if (toggleIcon) toggleIcon.className = 'fa fa-chevron-down';
                    }
                };
            }

            function escapeHtml(str) {
                if (!str) return '';
                var div = document.createElement('div');
                div.textContent = str;
                return div.innerHTML;
            }

            function addSaleRow(sale) {
                currentSaleCount++;
                var tbody = getEl('salesTableBody');
                var emptyMsg = getEl('salesEmpty');
                var tableWrap = getEl('salesTableWrap');

                if (emptyMsg) emptyMsg.classList.add('d-none');
                if (tableWrap) tableWrap.classList.remove('d-none');

                if (tbody) {
                    var tr = document.createElement('tr');
                    tr.style.animation = 'fadeIn 0.3s ease';
                    tr.innerHTML =
                        '<td>' + currentSaleCount + '</td>' +
                        '<td class="text-nowrap"><small>' + escapeHtml(sale.time) + '</small></td>' +
                        '<td style="white-space:normal;word-break:break-word"><small>' + escapeHtml(sale.products) + '</small></td>' +
                        '<td><small>' + escapeHtml(sale.scoutName || '') + '</small></td>' +
                        '<td><small>' + escapeHtml(sale.paymentMethod) + '</small></td>' +
                        '<td class="text-center">' + sale.totalQty + '</td>' +
                        '<td class="text-end text-nowrap"><strong>$' + sale.totalPrice.toFixed(2) + '</strong></td>' +
                        '<td><button type="button" class="btn btn-xs btn-outline-primary sale-edit-btn" data-sale-group-id="' + sale.id + '" title="Edit"><i class="fa fa-pencil"></i></button></td>';
                    tbody.insertBefore(tr, tbody.firstChild);
                }
            }

            // ══════════ SUBMIT SALE ══════════
            var submitBtn = getEl('cartSubmitBtn');
            if (submitBtn) {
                submitBtn.onclick = function() {
                    var items = [];
                    Object.keys(cart).forEach(function(pid) {
                        if (cart[pid].qty > 0) {
                            items.push({ productId: pid, qty: cart[pid].qty });
                        }
                    });

                    if (items.length === 0) { alert('Tap at least one cookie to sell.'); return; }

                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<i class="fa fa-spinner fa-spin me-1"></i> Saving...';

                    var scoutEl = getEl('boothScout');
                    var girlScoutId = scoutEl && scoutEl.value ? scoutEl.value : null;
                    var paymentEl = getEl('boothPayment');

                    fetch('@Url.Action("QuickAdd", "Boothing")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                        body: JSON.stringify({
                            date: selectedDate,
                            sessionId: sessionId || null,
                            paymentMethod: paymentEl ? paymentEl.value : 'Cash',
                            girlScoutId: girlScoutId,
                            notes: null,
                            items: items
                        })
                    }).then(function(r) {
                        if (r.ok) {
                            return r.json().then(function(d) {
                                if (d.kpi) updateKpis(d.kpi);
                                if (d.sale) addSaleRow(d.sale);

                                // Update booth inventory display
                                if (d.inventory) updateBoothInventory(d.inventory);

                                // Show warnings if oversold
                                if (d.warnings && d.warnings.length > 0) {
                                    alert('Warning: ' + d.warnings.join('\n'));
                                }

                                cart = {};
                                getAll('.product-card.selected').forEach(function(c) {
                                    c.classList.remove('selected');
                                    var qc = c.querySelector('.qty-controls');
                                    if (qc) qc.classList.add('d-none');
                                });
                                updateCart();

                                submitBtn.disabled = false;
                                submitBtn.innerHTML = '<i class="fa fa-check me-1"></i> Submit Sale';
                            });
                        } else {
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = '<i class="fa fa-check me-1"></i> Submit Sale';
                            r.json().then(function(d) { alert(d.error || 'Failed to record sale.'); });
                        }
                    }).catch(function() {
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '<i class="fa fa-check me-1"></i> Submit Sale';
                        alert('Network error. Please try again.');
                    });
                };
            }

            // ══════════ EDIT SALE MODAL ══════════
            var editSaleGroupId = null;
            var productData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProductCards.Select(p => new { id = p.Id.ToString(), name = p.Name, pricePerBox = p.PricePerBox })));

            function openEditModal(saleGroupId) {
                editSaleGroupId = saleGroupId;

                fetch('@Url.Action("GetSaleDetail", "Boothing")?id=' + editSaleGroupId)
                    .then(function(r) { return r.json(); })
                    .then(function(d) {
                        var payMethodEl = getEl('editPayMethod');
                        var notesEl = getEl('editNotes');
                        var scoutEl = getEl('editScout');
                        var container = getEl('editLineItems');

                        if (payMethodEl) payMethodEl.value = d.paymentMethod || 'Cash';
                        if (notesEl) notesEl.value = d.notes || '';
                        if (scoutEl) scoutEl.value = d.girlScoutId || '';

                        if (container) {
                            container.innerHTML = '';
                            d.lineItems.forEach(function(li) {
                                var row = document.createElement('div');
                                row.className = 'row align-items-center mb-2 edit-line';
                                row.innerHTML =
                                    '<div class="col-6"><select class="form-select form-select-sm edit-product">' +
                                    productData.map(function(p) {
                                        var sel = p.id === li.productId ? ' selected' : '';
                                        return '<option value="' + p.id + '" data-price="' + p.pricePerBox + '"' + sel + '>' + p.name + ' ($' + p.pricePerBox.toFixed(2) + ')</option>';
                                    }).join('') +
                                    '</select></div>' +
                                    '<div class="col-3"><input type="number" min="1" value="' + li.quantityBoxes + '" class="form-control form-control-sm edit-qty" /></div>' +
                                    '<div class="col-3 text-end"><strong class="edit-line-total">$' + li.lineTotal.toFixed(2) + '</strong></div>';
                                container.appendChild(row);
                            });
                        }

                        recalcEditTotal();
                        var modalEl = getEl('editSaleModal');
                        if (modalEl) {
                            var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                            modal.show();
                        }
                    }).catch(function() { alert('Failed to load sale details.'); });
            }

            function recalcEditTotal() {
                var total = 0;
                getAll('.edit-line').forEach(function(row) {
                    var sel = row.querySelector('.edit-product');
                    var qtyEl = row.querySelector('.edit-qty');
                    var qty = qtyEl ? (parseInt(qtyEl.value) || 0) : 0;
                    var opt = sel ? sel.options[sel.selectedIndex] : null;
                    var price = opt ? (parseFloat(opt.dataset.price) || 0) : 0;
                    var lineTotal = qty * price;
                    var ltEl = row.querySelector('.edit-line-total');
                    if (ltEl) ltEl.textContent = '$' + lineTotal.toFixed(2);
                    total += lineTotal;
                });
                var totalEl = getEl('editTotal');
                if (totalEl) totalEl.textContent = '$' + total.toFixed(2);
            }

            // Edit button click delegation
            document.addEventListener('click', function(e) {
                var editBtn = e.target.closest('.sale-edit-btn');
                if (editBtn && editBtn.dataset.saleGroupId) {
                    openEditModal(editBtn.dataset.saleGroupId);
                }
            });

            var editLineItems = getEl('editLineItems');
            if (editLineItems) {
                editLineItems.addEventListener('change', recalcEditTotal);
                editLineItems.addEventListener('input', recalcEditTotal);
            }

            var editSaveBtn = getEl('editSaveBtn');
            if (editSaveBtn) {
                editSaveBtn.onclick = function() {
                    if (!editSaleGroupId) return;

                    var items = [];
                    getAll('.edit-line').forEach(function(row) {
                        var pid = row.querySelector('.edit-product').value;
                        var qtyEl = row.querySelector('.edit-qty');
                        var qty = qtyEl ? (parseInt(qtyEl.value) || 0) : 0;
                        if (pid && qty > 0) items.push({ productId: pid, qty: qty });
                    });

                    var scoutEl = getEl('editScout');
                    var girlScoutId = scoutEl && scoutEl.value ? scoutEl.value : null;
                    var payMethodEl = getEl('editPayMethod');
                    var notesEl = getEl('editNotes');

                    fetch('@Url.Action("UpdateSale", "Boothing")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                        body: JSON.stringify({
                            saleGroupId: editSaleGroupId,
                            paymentMethod: payMethodEl ? payMethodEl.value : 'Cash',
                            notes: notesEl ? (notesEl.value || null) : null,
                            girlScoutId: girlScoutId,
                            items: items
                        })
                    }).then(function(r) {
                        if (r.ok) location.reload();
                        else r.json().then(function(d) { alert(d.error || 'Failed to save.'); });
                    }).catch(function() { alert('Network error.'); });
                };
            }

            var editDeleteBtn = getEl('editDeleteBtn');
            if (editDeleteBtn) {
                editDeleteBtn.onclick = function() {
                    if (!editSaleGroupId) return;
                    if (!confirm('Delete this sale? This cannot be undone.')) return;

                    fetch('@Url.Action("DeleteSale", "Boothing")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                        body: JSON.stringify({ saleGroupId: editSaleGroupId })
                    }).then(function(r) {
                        if (r.ok) location.reload();
                        else r.json().then(function(d) { alert(d.error || 'Failed to delete.'); });
                    }).catch(function() { alert('Network error.'); });
                };
            }

            console.log('[BoothSales] All event handlers attached');
        });
    </script>
}
