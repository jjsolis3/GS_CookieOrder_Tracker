<!-- ═══════════ QUICK ORDER MODAL (Global) ═══════════ -->
<div class="modal fade" id="quickOrderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary">
                <h5 class="modal-title text-white"><i class="fa fa-cookie-bite me-2"></i>Quick Order</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Loading spinner -->
                <div id="qoLoading" class="text-center py-4">
                    <i class="fa fa-spinner fa-spin fa-2x text-primary"></i>
                    <p class="text-muted mt-2">Loading products...</p>
                </div>

                <!-- Modal content (hidden until loaded) -->
                <div id="qoContent" class="d-none">
                    <!-- Order details row -->
                    <div class="row mb-3">
                        <div class="col-md-4 mb-2">
                            <label class="form-label small fw-bold">Order Type</label>
                            <select id="qoOrderType" class="form-select form-select-sm">
                                <option value="Direct Sale">Direct Sale</option>
                                <option value="Online Delivery">Online Delivery</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label small fw-bold">Customer</label>
                            <select id="qoCustomer" class="form-select form-select-sm">
                                <option value="">-- select customer --</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label small fw-bold">Girl Scout</label>
                            <select id="qoScout" class="form-select form-select-sm">
                                <option value="">Unassigned</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4 mb-2">
                            <label class="form-label small fw-bold">Payment Method</label>
                            <select id="qoPayment" class="form-select form-select-sm">
                                <option value="Cash">Cash</option>
                                <option value="Credit Card">Credit Card</option>
                                <option value="Venmo">Venmo</option>
                                <option value="Zelle">Zelle</option>
                                <option value="Check">Check</option>
                                <option value="Online Payment">Online Payment</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label small fw-bold">Inv. Source</label>
                            <select id="qoInvSource" class="form-select form-select-sm">
                                <option value="Personal">Personal</option>
                                <option value="Troop">Troop</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label small fw-bold">Notes</label>
                            <input id="qoNotes" class="form-control form-control-sm" placeholder="Optional notes..." />
                        </div>
                    </div>

                    <hr class="my-2">

                    <!-- Cart summary -->
                    <div id="qoCartSummary" class="alert alert-primary py-2 mb-3 d-none">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong id="qoCartItems">0</strong> product(s) &middot;
                                <strong id="qoCartBoxes">0</strong> boxes
                            </div>
                            <div>
                                <span class="text-muted">Total:</span>
                                <strong id="qoCartTotal" class="fs-4 text-primary ms-1">$0.00</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Product grid -->
                    <p class="text-muted small mb-2"><i class="fa fa-hand-pointer me-1"></i> Tap a cookie to add it to the order</p>
                    <div class="row g-2" id="qoProductGrid">
                        <!-- Populated via JavaScript -->
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary me-auto" id="qoClearBtn">
                    <i class="fa fa-times me-1"></i> Clear
                </button>
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="qoSubmitBtn" disabled>
                    <i class="fa fa-save me-1"></i> Save Order
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Floating Action Button for Quick Order -->
<button type="button" class="btn btn-primary rounded-circle shadow-lg" id="quickOrderFab"
        title="Quick Order"
        style="position:fixed; bottom:24px; right:24px; width:56px; height:56px; z-index:1040; font-size:1.3rem; display:flex; align-items:center; justify-content:center;">
    <i class="fa fa-plus"></i>
</button>

<style>
    #quickOrderFab {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    #quickOrderFab:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 20px rgba(0,0,0,0.3) !important;
    }
    .qo-product-card {
        cursor: pointer;
        transition: all 0.15s ease;
        border: 2px solid transparent;
    }
    .qo-product-card:hover {
        border-color: rgba(0, 123, 255, 0.3);
    }
    .qo-product-card.selected {
        border-color: #007bff !important;
        box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.5);
        background: rgba(0, 123, 255, 0.04);
    }
    .qo-product-card:active {
        transform: scale(0.97);
    }
    .qo-qty-controls {
        display: none;
    }
    .qo-product-card.selected .qo-qty-controls {
        display: flex;
    }
</style>

<script>
    (function () {
        var csrfMeta = document.querySelector('meta[name="csrf-token"]');
        var csrfToken = csrfMeta ? csrfMeta.content : '';
        var qoCart = {};
        var qoDataLoaded = false;

        // FAB click: open modal
        var fab = document.getElementById('quickOrderFab');
        if (fab) {
            fab.addEventListener('click', function () {
                var modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('quickOrderModal'));
                modal.show();
                if (!qoDataLoaded) loadQuickOrderData();
            });
        }

        function loadQuickOrderData() {
            fetch('/Orders/GetQuickOrderData')
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    qoDataLoaded = true;
                    document.getElementById('qoLoading').classList.add('d-none');
                    document.getElementById('qoContent').classList.remove('d-none');

                    // Populate customers
                    var custSel = document.getElementById('qoCustomer');
                    custSel.innerHTML = '<option value="">-- select customer --</option>';
                    data.customers.forEach(function (c) {
                        var opt = document.createElement('option');
                        opt.value = c.id;
                        opt.textContent = c.name;
                        custSel.appendChild(opt);
                    });

                    // Populate scouts (auto-select first real scout)
                    var scoutSel = document.getElementById('qoScout');
                    scoutSel.innerHTML = '<option value="">Unassigned</option>';
                    data.scouts.forEach(function (s, idx) {
                        var opt = document.createElement('option');
                        opt.value = s.id;
                        opt.textContent = s.name;
                        if (idx === 0) opt.selected = true;
                        scoutSel.appendChild(opt);
                    });

                    // Build product grid
                    var grid = document.getElementById('qoProductGrid');
                    grid.innerHTML = '';
                    data.products.forEach(function (p) {
                        var imgSrc = p.imagePath || '/images/pre.gif';
                        var col = document.createElement('div');
                        col.className = 'col-6 col-sm-4 col-md-3';
                        col.innerHTML =
                            '<div class="card qo-product-card h-100 text-center" data-product-id="' + p.id + '" data-product-name="' + escHtml(p.name) + '" data-price="' + p.pricePerBox + '">' +
                            '<div class="card-body p-2">' +
                            '<img src="' + escHtml(imgSrc) + '" alt="' + escHtml(p.name) + '" class="mb-1 rounded" style="width:64px;height:64px;object-fit:contain;" />' +
                            '<p class="mb-0 fw-bold small" style="line-height:1.2">' + escHtml(p.name) + '</p>' +
                            '<small class="text-success fw-bold">$' + p.pricePerBox.toFixed(2) + '</small>' +
                            '<div class="qo-qty-controls align-items-center justify-content-center gap-1 mt-1">' +
                            '<button type="button" class="btn btn-outline-danger btn-xs qo-minus" style="width:28px;height:28px;padding:0"><i class="fa fa-minus" style="font-size:0.7rem"></i></button>' +
                            '<input type="number" class="form-control form-control-sm text-center qo-qty" value="1" min="1" style="width:44px;height:28px;padding:2px" />' +
                            '<button type="button" class="btn btn-outline-success btn-xs qo-plus" style="width:28px;height:28px;padding:0"><i class="fa fa-plus" style="font-size:0.7rem"></i></button>' +
                            '</div>' +
                            '</div></div>';
                        grid.appendChild(col);
                    });

                    attachCardEvents();
                })
                .catch(function () {
                    document.getElementById('qoLoading').innerHTML = '<p class="text-danger">Failed to load. Please try again.</p>';
                });
        }

        function escHtml(str) {
            if (!str) return '';
            var d = document.createElement('div');
            d.textContent = str;
            return d.innerHTML;
        }

        function attachCardEvents() {
            var cards = document.querySelectorAll('.qo-product-card');
            cards.forEach(function (card) {
                card.addEventListener('click', function (e) {
                    if (e.target.closest('.qo-minus') || e.target.closest('.qo-plus') || e.target.classList.contains('qo-qty')) return;

                    var pid = card.dataset.productId;
                    if (card.classList.contains('selected')) {
                        card.classList.remove('selected');
                        delete qoCart[pid];
                    } else {
                        card.classList.add('selected');
                        card.querySelector('.qo-qty').value = 1;
                        qoCart[pid] = { name: card.dataset.productName, price: parseFloat(card.dataset.price) || 0, qty: 1 };
                    }
                    updateQoCart();
                });

                var minus = card.querySelector('.qo-minus');
                var plus = card.querySelector('.qo-plus');
                var qtyInp = card.querySelector('.qo-qty');

                if (minus) minus.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var pid = card.dataset.productId;
                    var v = Math.max(1, (parseInt(qtyInp.value) || 1) - 1);
                    qtyInp.value = v;
                    if (qoCart[pid]) qoCart[pid].qty = v;
                    updateQoCart();
                });

                if (plus) plus.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var pid = card.dataset.productId;
                    var v = (parseInt(qtyInp.value) || 1) + 1;
                    qtyInp.value = v;
                    if (qoCart[pid]) qoCart[pid].qty = v;
                    updateQoCart();
                });

                if (qtyInp) {
                    qtyInp.addEventListener('click', function (e) { e.stopPropagation(); });
                    qtyInp.addEventListener('change', function () {
                        var pid = card.dataset.productId;
                        var v = Math.max(1, parseInt(qtyInp.value) || 1);
                        qtyInp.value = v;
                        if (qoCart[pid]) qoCart[pid].qty = v;
                        updateQoCart();
                    });
                }
            });
        }

        function updateQoCart() {
            var keys = Object.keys(qoCart);
            var summary = document.getElementById('qoCartSummary');
            var submitBtn = document.getElementById('qoSubmitBtn');

            if (keys.length === 0) {
                summary.classList.add('d-none');
                submitBtn.disabled = true;
                return;
            }

            summary.classList.remove('d-none');
            submitBtn.disabled = false;

            var totalBoxes = 0, totalPrice = 0;
            keys.forEach(function (pid) {
                totalBoxes += qoCart[pid].qty;
                totalPrice += qoCart[pid].qty * qoCart[pid].price;
            });

            document.getElementById('qoCartItems').textContent = keys.length;
            document.getElementById('qoCartBoxes').textContent = totalBoxes;
            document.getElementById('qoCartTotal').textContent = '$' + totalPrice.toFixed(2);
        }

        // Clear button
        var clearBtn = document.getElementById('qoClearBtn');
        if (clearBtn) {
            clearBtn.addEventListener('click', function () {
                qoCart = {};
                document.querySelectorAll('.qo-product-card.selected').forEach(function (c) {
                    c.classList.remove('selected');
                });
                updateQoCart();
            });
        }

        // Submit order
        var submitBtn = document.getElementById('qoSubmitBtn');
        if (submitBtn) {
            submitBtn.addEventListener('click', function () {
                var items = [];
                Object.keys(qoCart).forEach(function (pid) {
                    if (qoCart[pid].qty > 0) {
                        items.push({ productId: pid, qty: qoCart[pid].qty });
                    }
                });
                if (items.length === 0) { alert('Select at least one product.'); return; }

                var custVal = document.getElementById('qoCustomer').value;
                var scoutVal = document.getElementById('qoScout').value;

                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fa fa-spinner fa-spin me-1"></i> Saving...';

                fetch('/Orders/QuickCreate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                    body: JSON.stringify({
                        orderType: document.getElementById('qoOrderType').value,
                        customerId: custVal || null,
                        girlScoutId: scoutVal || null,
                        paymentMethod: document.getElementById('qoPayment').value,
                        inventorySource: document.getElementById('qoInvSource').value,
                        notes: document.getElementById('qoNotes').value.trim() || null,
                        orderDate: new Date().toISOString(),
                        items: items
                    })
                }).then(function (r) {
                    if (r.ok) {
                        return r.json().then(function (d) {
                            // Reset modal
                            qoCart = {};
                            document.querySelectorAll('.qo-product-card.selected').forEach(function (c) {
                                c.classList.remove('selected');
                            });
                            updateQoCart();
                            document.getElementById('qoNotes').value = '';
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = '<i class="fa fa-save me-1"></i> Save Order';

                            // Close modal and show success
                            bootstrap.Modal.getInstance(document.getElementById('quickOrderModal')).hide();
                            showQuickOrderToast('Order saved! Total: $' + (d.totalPrice || 0).toFixed(2) + ' (' + (d.totalQty || 0) + ' boxes)');
                        });
                    } else {
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '<i class="fa fa-save me-1"></i> Save Order';
                        r.json().then(function (d) { alert(d.error || 'Failed to create order.'); });
                    }
                }).catch(function () {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fa fa-save me-1"></i> Save Order';
                    alert('Network error. Please try again.');
                });
            });
        }

        function showQuickOrderToast(message) {
            var toast = document.createElement('div');
            toast.className = 'alert alert-success shadow-lg';
            toast.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;min-width:300px;animation:fadeIn 0.3s ease';
            toast.innerHTML = '<i class="fa fa-check-circle me-2"></i>' + message;
            document.body.appendChild(toast);
            setTimeout(function () {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.5s ease';
                setTimeout(function () { toast.remove(); }, 500);
            }, 3000);
        }
    })();
</script>
