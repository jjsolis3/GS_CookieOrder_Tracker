@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
<!DOCTYPE html>
<html lang="en">
<head>
    <partial name="YashAdmin/_Meta" />
    <meta name="csrf-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
    <title>@ViewData["Title"] - GS Cookie Order Tracker</title>
    <!-- Favicon icon -->
    <link rel="shortcut icon" type="image/png" href="~/yashadmin/images/favicon.png">
    <link href="~/yashadmin/vendor/bootstrap-select/dist/css/bootstrap-select.min.css" rel="stylesheet">
    <!-- Style css -->
    <link class="main-css" href="~/yashadmin/css/style.css" rel="stylesheet">
</head>
<body class="vh-100">
    @RenderBody()
    <!--**********************************
        Scripts
    ***********************************-->
    <!-- Required vendors -->
    <script src="~/yashadmin/vendor/global/global.min.js"></script>
    <script src="~/yashadmin/vendor/bootstrap-select/dist/js/bootstrap-select.min.js"></script>
    <script src="~/yashadmin/js/deznav-init.js"></script>
    <script src="~/yashadmin/js/custom.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
