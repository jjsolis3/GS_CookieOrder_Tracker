@{
    ViewData["Title"] = "Reset Password";
    Layout = "_LayoutAuth";
}

<div class="authincation h-100">
    <div class="container h-100">
        <div class="row justify-content-center h-100 align-items-center">
            <div class="col-md-6 col-lg-5">
                <div class="authincation-content">
                    <div class="row no-gutters">
                        <div class="col-xl-12">
                            <div class="auth-form">
                                <h4 class="text-center mb-4">Reset Password</h4>

                                <div id="resetForm">
                                    <div id="resetError" class="text-danger mb-3 d-none"></div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">New Password</label>
                                        <input id="newPassword" type="password" class="form-control" placeholder="Enter new password (min 6 chars)" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Confirm Password</label>
                                        <input id="confirmPassword" type="password" class="form-control" placeholder="Confirm new password" />
                                    </div>
                                    <div class="text-center">
                                        <button type="button" class="btn btn-primary btn-block" id="resetBtn">Reset Password</button>
                                    </div>
                                </div>

                                <div id="resetSuccess" class="d-none">
                                    <div class="alert alert-success">
                                        <i class="fa fa-check-circle me-1"></i>
                                        Your password has been reset successfully.
                                    </div>
                                    <div class="text-center mt-3">
                                        <a href="@Url.Action("Login", "Account")" class="btn btn-primary">Sign In</a>
                                    </div>
                                </div>

                                <div id="resetNoToken" class="d-none">
                                    <div class="alert alert-warning">
                                        <i class="fa fa-exclamation-triangle me-1"></i>
                                        No reset token found. Please use the link from your email, or request a new one.
                                    </div>
                                    <div class="text-center mt-3">
                                        <a href="@Url.Action("ForgotPassword", "Account")" class="btn btn-outline-primary">Request New Link</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Supabase sends: https://yoursite.com/#access_token=...&type=recovery
    // We need to parse the hash fragment to get the access_token.
    (function () {
        var hash = window.location.hash.substring(1); // remove '#'
        var params = new URLSearchParams(hash);
        var accessToken = params.get('access_token');
        var type = params.get('type');

        if (!accessToken || type !== 'recovery') {
            document.getElementById('resetForm').classList.add('d-none');
            document.getElementById('resetNoToken').classList.remove('d-none');
            return;
        }

        document.getElementById('resetBtn').addEventListener('click', function () {
            var pw = document.getElementById('newPassword').value;
            var cpw = document.getElementById('confirmPassword').value;
            var errDiv = document.getElementById('resetError');

            if (!pw || pw.length < 6) {
                errDiv.textContent = 'Password must be at least 6 characters.';
                errDiv.classList.remove('d-none');
                return;
            }
            if (pw !== cpw) {
                errDiv.textContent = 'Passwords do not match.';
                errDiv.classList.remove('d-none');
                return;
            }

            errDiv.classList.add('d-none');

            fetch('@Url.Action("ResetPassword", "Account")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ accessToken: accessToken, newPassword: pw })
            })
            .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
            .then(function (result) {
                if (result.ok) {
                    document.getElementById('resetForm').classList.add('d-none');
                    document.getElementById('resetSuccess').classList.remove('d-none');
                } else {
                    errDiv.textContent = result.data.error || 'Failed to reset password.';
                    errDiv.classList.remove('d-none');
                }
            });
        });
    })();
</script>
