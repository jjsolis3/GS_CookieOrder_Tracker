@model GS_CookieOrder_Tracker.Models.ProductCreateViewModel

@{
    ViewData["Title"] = "Add Product";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Add Product</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <h5 class="card-title mb-3">Basic Info</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label">Name</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="Sku" class="form-label">SKU</label>
                            <input asp-for="Sku" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="Category" class="form-label">Category</label>
                            <input asp-for="Category" class="form-control" />
                        </div>
                        <div class="col-12 mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <h5 class="card-title mt-4 mb-3">Pricing &amp; Packaging</h5>
                    <hr>
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <label asp-for="PricePerBox" class="form-label">Price per Box</label>
                            <input asp-for="PricePerBox" class="form-control" />
                            <span asp-validation-for="PricePerBox" class="text-danger"></span>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="BoxesPerCase" class="form-label">Boxes per Case</label>
                            <input asp-for="BoxesPerCase" class="form-control" />
                            <span asp-validation-for="BoxesPerCase" class="text-danger"></span>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="Cost" class="form-label">Cost</label>
                            <input asp-for="Cost" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="Reward" class="form-label">Reward</label>
                            <input asp-for="Reward" class="form-control" />
                        </div>
                    </div>

                    <h5 class="card-title mt-4 mb-3">Additional Details</h5>
                    <hr>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Vendor" class="form-label">Vendor</label>
                            <input asp-for="Vendor" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Barcode" class="form-label">Barcode</label>
                            <input asp-for="Barcode" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="ImagePath" class="form-label">Image Path</label>
                            <input asp-for="ImagePath" class="form-control" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label asp-for="SortOrder" class="form-label">Sort Order</label>
                            <input asp-for="SortOrder" class="form-control" type="number" />
                            <small class="text-muted">Lower = First</small>
                        </div>
                        <div class="col-md-2 mb-3">
                            <div class="form-check mt-4">
                                <input asp-for="Active" class="form-check-input" type="checkbox" />
                                <label asp-for="Active" class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">Save Product</button>
                        <a class="btn btn-outline-light ms-2" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
