@model GS_CookieOrder_Tracker.Models.InventoryStockViewModel

@{
    ViewData["Title"] = "Inventory";
}

<!-- INVENTORY KPI's -->
<div class="row">
    <div class="col-xl-3 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-primary mb-0">@Model.TotalBoxesReceived</h4>
                    <small class="text-muted">Boxes Received</small>
                </div>
                <div class="icon-box bg-primary-light rounded-circle">
                    <i class="fa fa-box-open text-primary" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-danger mb-0">@Model.TotalBoxesSold</h4>
                    <small class="text-muted">Boxes Sold (All)</small>
                </div>
                <div class="icon-box rounded-circle" style="background:rgba(255,94,94,.1)">
                    <i class="fa fa-shopping-cart text-danger" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-warning mb-0">@Model.TotalBoxesReturned</h4>
                    <small class="text-muted">Boxes Returned</small>
                </div>
                <div class="icon-box rounded-circle" style="background:rgba(248,185,64,.1)">
                    <i class="fa fa-undo text-warning" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-success mb-0">@Model.TotalBoxesOnHand</h4>
                    <small class="text-muted">Boxes On Hand</small>
                </div>
                <div class="icon-box bg-success-light rounded-circle">
                    <i class="fa fa-cubes text-success" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- STOCK BY PRODUCT TABLE -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title">Stock by Product</h4>
                <div class="d-flex gap-2">
                    <a class="btn btn-primary btn-sm" asp-action="Create">
                        <i class="fa fa-plus me-1"></i> Add Receipt
                    </a>
                    <a class="btn btn-outline-warning btn-sm" asp-action="Return">
                        <i class="fa fa-undo me-1"></i> Return Product
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-responsive-md table-hover table-sortable">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Received</th>
                                <th class="text-end">On Hand</th>                                
                                <th class="text-end">Sold (Personal)</th>
                                <th class="text-end">Sold (Online)</th>
                                <th class="text-end">Sold (Troop)</th>
                                <th class="text-end">Returned</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Products)
                            {
                                var onHandClass = p.BoxesOnHand <= 0 ? "text-danger" : p.BoxesOnHand < 12 ? "text-warning" : "text-success";
                                <tr>
                                    <td><strong>@p.ProductName</strong></td>
                                    <td class="text-end">@p.BoxesReceived</td>
                                    <td class="text-end"><strong class="@onHandClass">@p.BoxesOnHand</strong></td>
                                    <td class="text-end">@p.BoxesSoldPersonal</td>
                                    <td class="text-end">
                                        @if (p.BoxesSoldOnline > 0)
                                        {
                                            <span class="text-info">@p.BoxesSoldOnline</span>
                                        }
                                        else
                                        {
                                            <span>0</span>
                                        }
                                    </td>
                                    <td class="text-end">@p.BoxesSoldTroop</td>
                                    <td class="text-end">
                                        @if (p.BoxesReturned > 0)
                                        {
                                            <span class="text-warning">@p.BoxesReturned</span>
                                        }
                                        else
                                        {
                                            <span>0</span>
                                        }
                                    </td>
                                    
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="fw-bold">
                                <td>Totals</td>
                                <td class="text-end">@Model.TotalBoxesReceived</td>
                                <td class="text-end">@Model.TotalBoxesOnHand</td>
                                <td class="text-end">@Model.Products.Sum(p => p.BoxesSoldPersonal)</td>
                                <td class="text-end">@Model.Products.Sum(p => p.BoxesSoldOnline)</td>
                                <td class="text-end">@Model.Products.Sum(p => p.BoxesSoldTroop)</td>
                                <td class="text-end">@Model.TotalBoxesReturned</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <p class="text-muted small mt-2 mb-0">On Hand = Received &minus; Sold (Personal) &minus; Returned. Troop/Booth sales do not reduce your personal inventory. Online Delivery is a subset of Sold (Personal).</p>
            </div>
        </div>
    </div>
</div>

<!-- INVENTORY BATCHES (RECEIPTS) TABLE -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title">Inventory Receipts</h4>
                <a class="btn btn-primary btn-sm" asp-action="Create">
                    <i class="fa fa-plus me-1"></i> New Receipt
                </a>
            </div>
            <div class="card-body">
                @if (!Model.Batches.Any())
                {
                    <p class="text-muted text-center py-4">No inventory batches recorded yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-responsive-md table-hover table-sortable">
                            <thead>
                                <tr>
                                    <th>Pickup Date</th>
                                    <th>Status</th>
                                    <th>Type</th>
                                    <th>Girl Scout</th>
                                    <th class="text-end">Total Boxes</th>
                                    <th class="text-end">Total Cases</th>
                                    <th style="width:50px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var batch in Model.Batches)
                                {
                                    var batchStatusClass = batch.Status?.ToLower() switch
                                    {
                                        "received" => "badge-success",
                                        "pending pickup" => "badge-warning",
                                        "in transit" => "badge-info",
                                        "complete" => "badge-primary",
                                        "returned" => "badge-secondary",
                                        _ => "badge-secondary"
                                    };
                                    <tr>
                                        <td>@(batch.PickupDate?.ToString("MMM d, yyyy") ?? "N/A")</td>
                                        <td><span class="badge light @batchStatusClass">@batch.Status</span></td>
                                        <td>@batch.BatchType</td>
                                        <td>@(batch.GirlScout == null ? "Unassigned" : $"{batch.GirlScout.FirstName} {batch.GirlScout.LastName}")</td>
                                        <td class="text-end"><strong>@batch.TotalBoxes</strong></td>
                                        <td class="text-end">@batch.TotalCases</td>
                                        <td>
                                            <button type="button" class="btn btn-xs btn-outline-primary batch-detail-btn" data-batch-id="@batch.Id" title="View Details">
                                                <i class="fa fa-eye"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ BATCH DETAIL / EDIT MODAL ═══════════ -->
<div class="modal fade" id="batchDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Batch Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Status</label>
                        <select id="mdlBatchStatus" class="form-select form-select-sm">
                            <option value="Received">Received</option>
                            <option value="Pending Pickup">Pending Pickup</option>
                            <option value="In Transit">In Transit</option>
                            <option value="Complete">Complete</option>
                            <option value="Returned">Returned</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Type</label>
                        <select id="mdlBatchType" class="form-select form-select-sm">
                            <option value="Initial Order">Initial Order</option>
                            <option value="Restock">Restock</option>
                            <option value="Transfer">Transfer</option>
                            <option value="Distribution">Distribution</option>
                            <option value="Donation">Donation</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Pickup Date</label>
                        <input type="date" id="mdlBatchPickupDate" class="form-control form-control-sm" />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Girl Scout</label>
                        <p id="mdlBatchGirlScout" class="mb-0"></p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Notes</label>
                        <input type="text" id="mdlBatchNotes" class="form-control form-control-sm" />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Total Boxes</label>
                        <p id="mdlBatchTotalBoxes" class="mb-0 fs-5 text-primary fw-bold"></p>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Total Cases</label>
                        <p id="mdlBatchTotalCases" class="mb-0 fs-5"></p>
                    </div>
                </div>

                <hr>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0">Products Received</h6>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="mdlAddReceiptLineBtn">
                        <i class="fa fa-plus me-1"></i> Add Product
                    </button>
                </div>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end" style="width:90px">Boxes</th>
                            <th class="text-end" style="width:90px">Cases</th>
                            <th style="width:40px"></th>
                        </tr>
                    </thead>
                    <tbody id="mdlBatchReceipts"></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-danger me-auto" id="mdlBatchDeleteBtn">
                    <i class="fa fa-trash me-1"></i> Delete
                </button>
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="mdlBatchSaveBtn">
                    <i class="fa fa-save me-1"></i> Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            'use strict';

            var csrfMeta = document.querySelector('meta[name="csrf-token"]');
            var csrfToken = csrfMeta ? csrfMeta.content : '';
            var currentBatchId = null;
            var productsList = []; // loaded once from server

            // Load products for receipt dropdowns
            fetch('@Url.Action("GetProducts", "Inventory")')
                .then(function (r) { return r.json(); })
                .then(function (data) { productsList = data; });

            function buildProductSelect(selectedId) {
                var html = '<select class="form-select form-select-sm receipt-product-select">';
                html += '<option value="">-- Select --</option>';
                productsList.forEach(function (p) {
                    var sel = p.id === selectedId ? ' selected' : '';
                    html += '<option value="' + p.id + '"' + sel + '>' + p.name + '</option>';
                });
                html += '</select>';
                return html;
            }

            function addReceiptRow(productId, productName, boxes, cases) {
                var tbody = document.getElementById('mdlBatchReceipts');
                var tr = document.createElement('tr');
                tr.className = 'receipt-edit-row';
                tr.innerHTML = buildProductSelect(productId)
                    + '<td><input type="number" class="form-control form-control-sm text-end receipt-boxes" value="' + boxes + '" min="0"></td>'
                    + '<td><input type="number" class="form-control form-control-sm text-end receipt-cases" value="' + cases + '" min="0"></td>'
                    + '<td><button type="button" class="btn btn-xs btn-outline-danger remove-receipt-btn" title="Remove"><i class="fa fa-times"></i></button></td>';
                // Wrap the select in the first td
                var firstTd = document.createElement('td');
                firstTd.innerHTML = buildProductSelect(productId);
                tr.innerHTML = '';
                tr.appendChild(firstTd);
                var boxesTd = document.createElement('td');
                boxesTd.innerHTML = '<input type="number" class="form-control form-control-sm text-end receipt-boxes" value="' + boxes + '" min="0">';
                tr.appendChild(boxesTd);
                var casesTd = document.createElement('td');
                casesTd.innerHTML = '<input type="number" class="form-control form-control-sm text-end receipt-cases" value="' + cases + '" min="0">';
                tr.appendChild(casesTd);
                var actionTd = document.createElement('td');
                actionTd.innerHTML = '<button type="button" class="btn btn-xs btn-outline-danger remove-receipt-btn" title="Remove"><i class="fa fa-times"></i></button>';
                tr.appendChild(actionTd);
                tbody.appendChild(tr);
            }

            function updateTotals() {
                var rows = document.querySelectorAll('#mdlBatchReceipts .receipt-edit-row');
                var totalBoxes = 0, totalCases = 0;
                rows.forEach(function (row) {
                    totalBoxes += parseInt(row.querySelector('.receipt-boxes').value) || 0;
                    totalCases += parseInt(row.querySelector('.receipt-cases').value) || 0;
                });
                document.getElementById('mdlBatchTotalBoxes').textContent = totalBoxes;
                document.getElementById('mdlBatchTotalCases').textContent = totalCases;
            }

            function collectReceipts() {
                var rows = document.querySelectorAll('#mdlBatchReceipts .receipt-edit-row');
                var receipts = [];
                rows.forEach(function (row) {
                    var sel = row.querySelector('.receipt-product-select');
                    receipts.push({
                        productId: sel ? sel.value : '',
                        quantityBoxes: parseInt(row.querySelector('.receipt-boxes').value) || 0,
                        quantityCases: parseInt(row.querySelector('.receipt-cases').value) || 0
                    });
                });
                return receipts;
            }

            // Remove receipt row (delegated)
            document.getElementById('mdlBatchReceipts').addEventListener('click', function (e) {
                var btn = e.target.closest('.remove-receipt-btn');
                if (!btn) return;
                btn.closest('tr').remove();
                updateTotals();
            });

            // Update totals when inputs change (delegated)
            document.getElementById('mdlBatchReceipts').addEventListener('input', function (e) {
                if (e.target.classList.contains('receipt-boxes') || e.target.classList.contains('receipt-cases')) {
                    updateTotals();
                }
            });

            // Add new receipt line
            document.getElementById('mdlAddReceiptLineBtn').addEventListener('click', function () {
                addReceiptRow('', '', 0, 0);
            });

            document.querySelectorAll('.batch-detail-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    currentBatchId = this.dataset.batchId;
                    fetch('@Url.Action("GetBatchDetail", "Inventory")?id=' + currentBatchId)
                        .then(function (r) { return r.json(); })
                        .then(function (d) {
                            document.getElementById('mdlBatchStatus').value = d.status || 'Received';
                            document.getElementById('mdlBatchType').value = d.batchType || 'Initial Order';
                            document.getElementById('mdlBatchPickupDate').value = d.pickupDate || '';
                            document.getElementById('mdlBatchNotes').value = d.notes || '';
                            document.getElementById('mdlBatchGirlScout').textContent = d.girlScoutName || 'Unassigned';
                            document.getElementById('mdlBatchTotalBoxes').textContent = d.totalBoxes;
                            document.getElementById('mdlBatchTotalCases').textContent = d.totalCases;

                            var tbody = document.getElementById('mdlBatchReceipts');
                            tbody.innerHTML = '';
                            d.receipts.forEach(function (r) {
                                addReceiptRow(r.productId, r.productName, r.quantityBoxes, r.quantityCases);
                            });

                            var modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('batchDetailModal'));
                            modal.show();
                        }).catch(function() { alert('Failed to load batch details.'); });
                });
            });

            document.getElementById('mdlBatchSaveBtn').addEventListener('click', function () {
                fetch('@Url.Action("UpdateBatch", "Inventory")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                    body: JSON.stringify({
                        batchId: currentBatchId,
                        status: document.getElementById('mdlBatchStatus').value,
                        batchType: document.getElementById('mdlBatchType').value,
                        pickupDate: document.getElementById('mdlBatchPickupDate').value || null,
                        notes: document.getElementById('mdlBatchNotes').value || null,
                        receipts: collectReceipts()
                    })
                }).then(function (r) {
                    if (r.ok) location.reload();
                    else r.json().then(function (d) { alert(d.error || 'Failed to save.'); });
                }).catch(function() { alert('Network error.'); });
            });

            document.getElementById('mdlBatchDeleteBtn').addEventListener('click', function () {
                if (!confirm('Delete this batch and all its receipts? This cannot be undone.')) return;
                fetch('@Url.Action("DeleteBatch", "Inventory")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                    body: JSON.stringify({ batchId: currentBatchId })
                }).then(function (r) {
                    if (r.ok) location.reload();
                    else r.json().then(function (d) { alert(d.error || 'Failed to delete.'); });
                }).catch(function() { alert('Network error.'); });
            });
        })();
    </script>
}
