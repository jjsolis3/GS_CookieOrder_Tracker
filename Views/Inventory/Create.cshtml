@model GS_CookieOrder_Tracker.Models.InventoryBatchCreateViewModel

@{
    ViewData["Title"] = "New Inventory Receipt";
}

<h2 class="mb-3">New Inventory Receipt</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Status" class="form-label"></label>
            <input asp-for="Status" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="BatchType" class="form-label"></label>
            <input asp-for="BatchType" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="PickupDate" class="form-label"></label>
            <input asp-for="PickupDate" type="date" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="GirlScoutId" class="form-label">Girl Scout</label>
            <select asp-for="GirlScoutId" asp-items="Model.GirlScouts" class="form-select"></select>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Notes" class="form-label"></label>
            <input asp-for="Notes" class="form-control" />
        </div>
    </div>

    <h5 class="mt-3">Receipt Line</h5>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="ProductId" class="form-label"></label>
            <select asp-for="ProductId" asp-items="Model.Products" class="form-select"></select>
            <span asp-validation-for="ProductId" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="QuantityBoxes" class="form-label"></label>
            <input asp-for="QuantityBoxes" class="form-control" />
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="QuantityCases" class="form-label"></label>
            <input asp-for="QuantityCases" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save Receipt</button>
        <a class="btn btn-outline-secondary ms-2" asp-action="Index">Cancel</a>
    </div>
</form>
