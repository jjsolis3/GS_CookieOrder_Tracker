@model GS_CookieOrder_Tracker.Models.InventoryBatchCreateViewModel

@{
    ViewData["Title"] = "New Inventory Receipt";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">New Inventory Receipt</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Status" class="form-label">Status</label>
                            <input asp-for="Status" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="BatchType" class="form-label">Batch Type</label>
                            <input asp-for="BatchType" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="PickupDate" class="form-label">Pickup Date</label>
                            <input asp-for="PickupDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="GirlScoutId" class="form-label">Girl Scout</label>
                            <select asp-for="GirlScoutId" asp-items="Model.GirlScouts" class="form-select default-select"></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Notes" class="form-label">Notes</label>
                            <input asp-for="Notes" class="form-control" />
                        </div>
                    </div>

                    <h5 class="card-title mt-4 mb-3">Receipt Line</h5>
                    <hr>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ProductId" class="form-label">Product</label>
                            <select asp-for="ProductId" asp-items="Model.Products" class="form-select default-select"></select>
                            <span asp-validation-for="ProductId" class="text-danger"></span>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="QuantityBoxes" class="form-label">Boxes</label>
                            <input asp-for="QuantityBoxes" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="QuantityCases" class="form-label">Cases</label>
                            <input asp-for="QuantityCases" class="form-control" />
                        </div>
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">Save Receipt</button>
                        <a class="btn btn-outline-light ms-2" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
