@model GS_CookieOrder_Tracker.Models.InventoryBatchCreateViewModel

@{
    ViewData["Title"] = "New Inventory Receipt";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">New Inventory Receipt</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" asp-items="Model.Statuses" class="form-select default-select"></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="BatchType" class="form-label">Batch Type</label>
                            <select asp-for="BatchType" asp-items="Model.BatchTypes" class="form-select default-select"></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="PickupDate" class="form-label">Pickup Date</label>
                            <input asp-for="PickupDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="GirlScoutId" class="form-label">Girl Scout</label>
                            <select asp-for="GirlScoutId" asp-items="Model.GirlScouts" class="form-select default-select"></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Notes" class="form-label">Notes</label>
                            <input asp-for="Notes" class="form-control" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
                        <h5 class="card-title mb-0">Products</h5>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="addLineBtn">
                            <i class="fa fa-plus me-1"></i> Add Product
                        </button>
                    </div>
                    <hr class="mt-0">

                    <div id="linesContainer">
                        @for (int i = 0; i < Model.Lines.Count; i++)
                        {
                            <div class="row receipt-line align-items-end mb-2" data-index="@i">
                                <div class="col-md-5 mb-2">
                                    @if (i == 0) { <label class="form-label">Product</label> }
                                    <select name="Lines[@i].ProductId" class="form-select">
                                        <option value="">-- Select Product --</option>
                                        @foreach (var p in Model.Products)
                                        {
                                            var sel = p.Value == Model.Lines[i].ProductId.ToString() ? "selected" : "";
                                            <option value="@p.Value" @sel>@p.Text</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2 mb-2">
                                    @if (i == 0) { <label class="form-label">Boxes</label> }
                                    <input type="number" name="Lines[@i].QuantityBoxes" value="@Model.Lines[i].QuantityBoxes" min="0" class="form-control" />
                                </div>
                                <div class="col-md-2 mb-2">
                                    @if (i == 0) { <label class="form-label">Cases</label> }
                                    <input type="number" name="Lines[@i].QuantityCases" value="@Model.Lines[i].QuantityCases" min="0" class="form-control" />
                                </div>
                                <div class="col-md-2 mb-2">
                                    @if (i > 0)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger remove-line-btn">
                                            <i class="fa fa-trash"></i> Remove
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Save Receipt</button>
                        <a class="btn btn-outline-light ms-2" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            // Build product options HTML once for reuse
            var productOptions = '<option value="">-- Select Product --</option>';
            @foreach (var p in Model.Products)
            {
                @:productOptions += '<option value="@p.Value">@Html.Raw(p.Text.Replace("'", "\\'"))</option>';
            }

            document.getElementById('addLineBtn').addEventListener('click', function () {
                var container = document.getElementById('linesContainer');
                var rows = container.querySelectorAll('.receipt-line');
                var idx = rows.length;

                var html = '<div class="row receipt-line align-items-end mb-2" data-index="' + idx + '">'
                    + '<div class="col-md-5 mb-2"><select name="Lines[' + idx + '].ProductId" class="form-select">' + productOptions + '</select></div>'
                    + '<div class="col-md-2 mb-2"><input type="number" name="Lines[' + idx + '].QuantityBoxes" value="0" min="0" class="form-control" /></div>'
                    + '<div class="col-md-2 mb-2"><input type="number" name="Lines[' + idx + '].QuantityCases" value="0" min="0" class="form-control" /></div>'
                    + '<div class="col-md-2 mb-2"><button type="button" class="btn btn-sm btn-outline-danger remove-line-btn"><i class="fa fa-trash"></i> Remove</button></div>'
                    + '</div>';

                container.insertAdjacentHTML('beforeend', html);
            });

            document.getElementById('linesContainer').addEventListener('click', function (e) {
                var btn = e.target.closest('.remove-line-btn');
                if (!btn) return;
                btn.closest('.receipt-line').remove();
                reindex();
            });

            function reindex() {
                var rows = document.querySelectorAll('#linesContainer .receipt-line');
                rows.forEach(function (row, i) {
                    row.dataset.index = i;
                    var sel = row.querySelector('select');
                    if (sel) sel.name = 'Lines[' + i + '].ProductId';
                    var inputs = row.querySelectorAll('input[type="number"]');
                    if (inputs[0]) inputs[0].name = 'Lines[' + i + '].QuantityBoxes';
                    if (inputs[1]) inputs[1].name = 'Lines[' + i + '].QuantityCases';
                });
            }
        })();
    </script>
}
