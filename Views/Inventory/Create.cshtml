@model GS_CookieOrder_Tracker.Models.InventoryBatchCreateViewModel

@{
    ViewData["Title"] = "New Inventory Receipt";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">New Inventory Receipt</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" id="receiptForm">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" asp-items="Model.Statuses" class="form-select default-select"></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="BatchType" class="form-label">Batch Type</label>
                            <select asp-for="BatchType" asp-items="Model.BatchTypes" class="form-select default-select"></select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="GirlScoutId" class="form-label">Girl Scout</label>
                            <select asp-for="GirlScoutId" asp-items="Model.GirlScouts" class="form-select default-select"></select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PickupDate" class="form-label">Pickup Date</label>
                            <input asp-for="PickupDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Notes" class="form-label">Notes</label>
                            <input asp-for="Notes" class="form-control" />
                        </div>
                    </div>

                    <h5 class="card-title mt-4 mb-3">Select Products</h5>
                    <p class="text-muted small mb-3">Tap a product to add it. Enter the number of boxes and/or cases received.</p>

                    <!-- Product Card Grid -->
                    <div class="row g-2 mb-3" id="productCardGrid">
                        @foreach (var card in Model.ProductCards)
                        {
                            var imgSrc = !string.IsNullOrEmpty(card.ImagePath) ? card.ImagePath : "/images/pre.gif";
                            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                                <div class="card inv-product-card h-100 text-center border"
                                     data-product-id="@card.Id"
                                     data-product-name="@card.Name"
                                     data-boxes-per-case="@card.BoxesPerCase"
                                     style="cursor:pointer; transition: all 0.15s ease; opacity:0.6">
                                    <div class="card-body p-2">
                                        <img src="@imgSrc" alt="@card.Name" class="mb-1 rounded" style="width:64px; height:64px; object-fit:contain;" />
                                        <p class="mb-0 fw-bold small" style="line-height:1.2">@card.Name</p>
                                        <small class="text-muted">@card.BoxesPerCase boxes/case</small>
                                        <!-- Quantity controls (hidden until selected) -->
                                        <div class="qty-controls d-none mt-2">
                                            <div class="row g-1">
                                                <div class="col-6">
                                                    <label class="form-label mb-0" style="font-size:.65rem">Boxes</label>
                                                    <input type="number" class="form-control form-control-sm text-center inv-boxes" value="0" min="0" />
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label mb-0" style="font-size:.65rem">Cases</label>
                                                    <input type="number" class="form-control form-control-sm text-center inv-cases" value="0" min="0" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Summary bar -->
                    <div class="card bg-light mb-3" id="receiptSummaryCard">
                        <div class="card-body py-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-muted">Products:</span>
                                    <strong id="summaryProductCount" class="ms-1">0</strong>
                                    <span class="text-muted ms-3">Total Boxes:</span>
                                    <strong id="summaryTotalBoxes" class="ms-1">0</strong>
                                    <span class="text-muted ms-3">Total Cases:</span>
                                    <strong id="summaryTotalCases" class="ms-1">0</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Hidden inputs container for form submission -->
                    <div id="hiddenLinesContainer"></div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-save me-1"></i> Save Receipt
                        </button>
                        <a class="btn btn-outline-light ms-2" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            'use strict';

            var cards = document.querySelectorAll('.inv-product-card');

            cards.forEach(function (card) {
                card.addEventListener('click', function (e) {
                    // Don't toggle if clicking on inputs
                    if (e.target.tagName === 'INPUT') return;

                    var controls = card.querySelector('.qty-controls');
                    var isSelected = !controls.classList.contains('d-none');

                    if (isSelected) {
                        // Deselect
                        controls.classList.add('d-none');
                        card.style.opacity = '0.6';
                        card.style.borderColor = '';
                        card.style.boxShadow = '';
                        card.querySelector('.inv-boxes').value = 0;
                        card.querySelector('.inv-cases').value = 0;
                    } else {
                        // Select
                        controls.classList.remove('d-none');
                        card.style.opacity = '1';
                        card.style.borderColor = '#0d6efd';
                        card.style.boxShadow = '0 0 0 2px rgba(13,110,253,.25)';
                        card.querySelector('.inv-boxes').focus();
                    }
                    updateSummary();
                });
            });

            // Delegate input changes for summary update
            document.getElementById('productCardGrid').addEventListener('input', function () {
                updateSummary();
            });

            function updateSummary() {
                var selectedCards = document.querySelectorAll('.inv-product-card .qty-controls:not(.d-none)');
                var productCount = 0, totalBoxes = 0, totalCases = 0;

                selectedCards.forEach(function (ctrl) {
                    var card = ctrl.closest('.inv-product-card');
                    var boxes = parseInt(card.querySelector('.inv-boxes').value) || 0;
                    var cases = parseInt(card.querySelector('.inv-cases').value) || 0;
                    if (boxes > 0 || cases > 0) productCount++;
                    totalBoxes += boxes;
                    totalCases += cases;
                });

                document.getElementById('summaryProductCount').textContent = productCount;
                document.getElementById('summaryTotalBoxes').textContent = totalBoxes;
                document.getElementById('summaryTotalCases').textContent = totalCases;
            }

            // Before form submit, build hidden inputs from card selections
            document.getElementById('receiptForm').addEventListener('submit', function () {
                var container = document.getElementById('hiddenLinesContainer');
                container.innerHTML = '';
                var idx = 0;

                document.querySelectorAll('.inv-product-card').forEach(function (card) {
                    var controls = card.querySelector('.qty-controls');
                    if (controls.classList.contains('d-none')) return;

                    var boxes = parseInt(card.querySelector('.inv-boxes').value) || 0;
                    var cases = parseInt(card.querySelector('.inv-cases').value) || 0;
                    if (boxes === 0 && cases === 0) return;

                    var productId = card.dataset.productId;
                    container.innerHTML += '<input type="hidden" name="Lines[' + idx + '].ProductId" value="' + productId + '">'
                        + '<input type="hidden" name="Lines[' + idx + '].QuantityBoxes" value="' + boxes + '">'
                        + '<input type="hidden" name="Lines[' + idx + '].QuantityCases" value="' + cases + '">';
                    idx++;
                });
            });
        })();
    </script>
}
