@model IEnumerable<GS_CookieOrder_Tracker.Data.InventoryBatch>

@{
    ViewData["Title"] = "Inventory";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Inventory Batches</h2>
    <a class="btn btn-primary" asp-action="Create">New Receipt</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Pickup Date</th>
            <th>Status</th>
            <th>Type</th>
            <th>Girl Scout</th>
            <th>Total Boxes</th>
            <th>Total Cases</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var batch in Model)
        {
            <tr>
                <td>@(batch.PickupDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                <td>@batch.Status</td>
                <td>@batch.BatchType</td>
                <td>@(batch.GirlScout == null ? "Unassigned" : $"{batch.GirlScout.FirstName} {batch.GirlScout.LastName}")</td>
                <td>@batch.TotalBoxes</td>
                <td>@batch.TotalCases</td>
            </tr>
        }
    </tbody>
</table>
