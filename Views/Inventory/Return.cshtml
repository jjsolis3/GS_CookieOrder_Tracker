@model GS_CookieOrder_Tracker.Models.InventoryReturnCreateViewModel

@{
    ViewData["Title"] = "Return Product";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Return Product to Troop</h4>
            </div>
            <div class="card-body">
                <p class="text-muted mb-4">Tap the product to return, then enter the quantity. Returned product will be removed from your personal inventory and payback responsibility.</p>
                <form asp-action="Return" method="post" id="returnForm">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <!-- Product Card Grid (single selection) -->
                    <h5 class="card-title mb-3">Select Product</h5>
                    <div class="row g-2 mb-3" id="returnProductGrid">
                        @foreach (var card in Model.ProductCards)
                        {
                            var imgSrc = !string.IsNullOrEmpty(card.ImagePath) ? card.ImagePath : "/images/pre.gif";
                            var isSelected = card.Id == Model.ProductId;
                            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                                <div class="card ret-product-card h-100 text-center border"
                                     data-product-id="@card.Id"
                                     style="cursor:pointer; transition: all 0.15s ease; @(isSelected ? "opacity:1; border-color:#e65100 !important; box-shadow:0 0 0 2px rgba(230,81,0,.25);" : "opacity:0.6;")">
                                    <div class="card-body p-2">
                                        <img src="@imgSrc" alt="@card.Name" class="mb-1 rounded" style="width:64px; height:64px; object-fit:contain;" />
                                        <p class="mb-0 fw-bold small" style="line-height:1.2">@card.Name</p>
                                        <small class="text-muted">@card.BoxesPerCase boxes/case</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <input type="hidden" asp-for="ProductId" id="selectedProductId" />

                    <!-- Return details (shown after product selection) -->
                    <div id="returnDetails" class="@(Model.ProductId != Guid.Empty ? "" : "d-none")">
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h6 class="mb-3">
                                    Return details for: <strong id="returnProductName">@(Model.ProductCards.FirstOrDefault(p => p.Id == Model.ProductId)?.Name ?? "")</strong>
                                </h6>
                                <div class="row">
                                    <div class="col-md-3 mb-3">
                                        <label asp-for="QuantityBoxes" class="form-label fw-bold">Boxes</label>
                                        <input asp-for="QuantityBoxes" class="form-control" min="0" />
                                        <span asp-validation-for="QuantityBoxes" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-3 mb-3">
                                        <label asp-for="QuantityCases" class="form-label fw-bold">Cases</label>
                                        <input asp-for="QuantityCases" class="form-control" min="0" />
                                        <span asp-validation-for="QuantityCases" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-3 mb-3">
                                        <label asp-for="Reason" class="form-label fw-bold">Reason</label>
                                        <select asp-for="Reason" class="form-select">
                                            <option value="">-- Select --</option>
                                            <option value="Unsold">Unsold</option>
                                            <option value="Damaged">Damaged</option>
                                            <option value="Excess">Excess</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3 mb-3">
                                        <label asp-for="Notes" class="form-label fw-bold">Notes</label>
                                        <input asp-for="Notes" class="form-control" placeholder="Optional..." />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-warning">
                            <i class="fa fa-undo me-1"></i> Submit Return
                        </button>
                        <a class="btn btn-outline-light ms-2" asp-action="Stock">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            'use strict';

            var cards = document.querySelectorAll('.ret-product-card');
            var selectedProductId = document.getElementById('selectedProductId');
            var returnDetails = document.getElementById('returnDetails');
            var productNameEl = document.getElementById('returnProductName');

            cards.forEach(function (card) {
                card.addEventListener('click', function () {
                    // Deselect all
                    cards.forEach(function (c) {
                        c.style.opacity = '0.6';
                        c.style.borderColor = '';
                        c.style.boxShadow = '';
                    });

                    // Select this one
                    card.style.opacity = '1';
                    card.style.borderColor = '#e65100';
                    card.style.boxShadow = '0 0 0 2px rgba(230,81,0,.25)';

                    selectedProductId.value = card.dataset.productId;
                    productNameEl.textContent = card.querySelector('.fw-bold').textContent;
                    returnDetails.classList.remove('d-none');
                    document.getElementById('QuantityBoxes').focus();
                });
            });
        })();
    </script>
}
