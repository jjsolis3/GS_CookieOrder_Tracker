@model GS_CookieOrder_Tracker.Models.PaybackSummaryViewModel

@{
    ViewData["Title"] = "Payback Report";
}

<!-- Summary cards -->
<div class="row">
    <div class="col-xl-3 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-danger mb-0">@Model.TotalOwedFromSales.ToString("C")</h4>
                    <small class="text-muted">Owed from Sales</small>
                </div>
                <div class="icon-box rounded-circle" style="background:rgba(255,94,94,.1)">
                    <i class="fa fa-exclamation-circle text-danger" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
    @if (Model.TotalReturnedValue > 0)
    {
        <div class="col-xl-3 col-sm-6">
            <div class="card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="text-warning mb-0">&minus;@Model.TotalReturnedValue.ToString("C")</h4>
                        <small class="text-muted">Return Credit</small>
                    </div>
                    <div class="icon-box rounded-circle" style="background:rgba(248,185,64,.1)">
                        <i class="fa fa-undo text-warning" style="font-size:1.2rem"></i>
                    </div>
                </div>
            </div>
        </div>
    }
    <div class="col-xl-3 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-success mb-0">@Model.TotalPaid.ToString("C")</h4>
                    <small class="text-muted">Total Paid Back</small>
                </div>
                <div class="icon-box bg-success-light rounded-circle">
                    <i class="fa fa-check-circle text-success" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="text-info mb-0">@Model.TotalBoxesPaid</h4>
                    <small class="text-muted">Boxes Paid</small>
                </div>
                <div class="icon-box rounded-circle" style="background:rgba(54,153,255,.1)">
                    <i class="fa fa-box text-info" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    @{
                        var remColor = Model.TotalRemaining > 0 ? "text-warning" : "text-success";
                    }
                    <h4 class="@remColor mb-0">@Model.TotalRemaining.ToString("C")</h4>
                    <small class="text-muted">Remaining Balance</small>
                </div>
                <div class="icon-box bg-secondary-light rounded-circle">
                    <i class="fa fa-balance-scale text-warning" style="font-size:1.2rem"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Owed by product / Paid by product -->
<div class="row">
    <div class="col-xl-6 col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Owed by Product</h4>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm table-sortable">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Boxes Sold</th>
                                <th class="text-end">Price/Box</th>
                                <th class="text-end">Amount Owed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.ByProduct)
                            {
                                <tr>
                                    <td>@row.ProductName</td>
                                    <td class="text-end">@row.BoxesSold</td>
                                    <td class="text-end">@row.PricePerBox.ToString("C")</td>
                                    <td class="text-end"><strong>@row.AmountOwed.ToString("C")</strong></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="fw-bold">
                                <td colspan="3">Subtotal from Sales</td>
                                <td class="text-end">@Model.TotalOwedFromSales.ToString("C")</td>
                            </tr>
                            @if (Model.TotalReturnedValue > 0)
                            {
                                <tr class="text-warning">
                                    <td colspan="3"><i class="fa fa-undo me-1"></i>Return Credit</td>
                                    <td class="text-end">&minus;@Model.TotalReturnedValue.ToString("C")</td>
                                </tr>
                            }
                            <tr class="fw-bold">
                                <td colspan="3">Net Owed</td>
                                <td class="text-end">@Model.TotalOwed.ToString("C")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <p class="text-muted small mt-2 mb-0">Online Delivery orders are excluded. Returned product reduces the amount owed.</p>
            </div>
        </div>
    </div>

    <div class="col-xl-6 col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Paid by Product</h4>
            </div>
            <div class="card-body">
                @if (!Model.PaidByProduct.Any())
                {
                    <p class="text-muted text-center py-4">No payments recorded yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-sortable">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th class="text-end">Boxes Paid</th>
                                    <th class="text-end">Price/Box</th>
                                    <th class="text-end">Amount Paid</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.PaidByProduct)
                                {
                                    <tr>
                                        <td>@row.ProductName</td>
                                        <td class="text-end">@row.BoxesSold</td>
                                        <td class="text-end">@row.PricePerBox.ToString("C")</td>
                                        <td class="text-end"><strong class="text-success">@row.AmountOwed.ToString("C")</strong></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="fw-bold">
                                    <td colspan="3">Total Paid (by Order Value)</td>
                                    <td class="text-end text-success">@Model.PaidByProduct.Sum(r => r.AmountOwed).ToString("C")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    <p class="text-muted small mt-2 mb-0">Products from orders that have associated payback records.</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Recent payments -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Recent Payments</h4>
                <a class="btn btn-primary btn-sm" asp-action="Create">
                    <i class="fa fa-plus me-1"></i> Record Payment
                </a>
            </div>
            <div class="card-body">
                @if (!Model.RecentPayments.Any())
                {
                    <p class="text-muted text-center py-4">No payments recorded yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover table-sortable">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Amount</th>
                                    <th>Method</th>
                                    <th>Order / Product</th>
                                    <th>Notes</th>
                                    <th class="text-end">Running Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pay in Model.RecentPayments)
                                {
                                    var methodClass = pay.Method?.ToLower() switch
                                    {
                                        "cash" => "badge-success",
                                        "check" => "badge-warning",
                                        "bank transfer" => "badge-info",
                                        _ => "badge-primary"
                                    };
                                    <tr>
                                        <td>@pay.PaidAt.ToString("yyyy-MM-dd")</td>
                                        <td><strong>@pay.Amount.ToString("C")</strong></td>
                                        <td><span class="badge light @methodClass">@pay.Method</span></td>
                                        <td><small>@pay.OrderInfo</small></td>
                                        <td><small class="text-muted">@pay.Notes</small></td>
                                        <td class="text-end"><strong class="text-success">@pay.RunningTotal.ToString("C")</strong></td>
                                        <td>
                                            <button type="button" class="btn btn-xs btn-outline-primary payment-edit-btn"
                                                    data-id="@pay.Id"
                                                    data-paid-at="@pay.PaidAt.ToString("yyyy-MM-dd")"
                                                    data-amount="@pay.Amount"
                                                    data-method="@pay.Method"
                                                    data-notes="@pay.Notes"
                                                    data-order-info="@pay.OrderInfo"
                                                    title="Edit Payment">
                                                <i class="fa fa-pencil"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="fw-bold bg-light">
                                    <td colspan="6">Net Paid (Total)</td>
                                    <td class="text-end text-success">@Model.TotalPaid.ToString("C")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ PAYMENT DETAIL / EDIT MODAL ═══════════ -->
<div class="modal fade" id="paymentEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Payment Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Payment Date</label>
                        <input type="date" id="mdlPayPaidAt" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Amount</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">$</span>
                            <input type="number" step="0.01" min="0" id="mdlPayAmount" class="form-control form-control-sm" />
                        </div>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Method</label>
                        <select id="mdlPayMethod" class="form-select form-select-sm">
                            <option value="Check">Check</option>
                            <option value="Cash">Cash</option>
                            <option value="Bank Transfer">Bank Transfer</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Order</label>
                        <p id="mdlPayOrderInfo" class="mb-0 text-muted small"></p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-12">
                        <label class="form-label fw-bold">Notes</label>
                        <input type="text" id="mdlPayNotes" class="form-control form-control-sm" placeholder="e.g. Check #12345" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-danger me-auto" id="mdlPayDeleteBtn">
                    <i class="fa fa-trash me-1"></i> Delete
                </button>
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="mdlPaySaveBtn">
                    <i class="fa fa-save me-1"></i> Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var csrfToken = document.querySelector('meta[name="csrf-token"]').content;
        var currentPaymentId = null;

        // ── Open payment edit modal ──
        document.querySelectorAll('.payment-edit-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                currentPaymentId = this.dataset.id;
                document.getElementById('mdlPayPaidAt').value = this.dataset.paidAt || '';
                document.getElementById('mdlPayAmount').value = this.dataset.amount || '';
                document.getElementById('mdlPayMethod').value = this.dataset.method || 'Check';
                document.getElementById('mdlPayNotes').value = this.dataset.notes || '';
                document.getElementById('mdlPayOrderInfo').textContent = this.dataset.orderInfo || 'N/A';

                var modalEl = document.getElementById('paymentEditModal');
                var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                modal.show();
            });
        });

        // ── Save payment changes ──
        document.getElementById('mdlPaySaveBtn').addEventListener('click', function () {
            if (!currentPaymentId) return;

            var amount = parseFloat(document.getElementById('mdlPayAmount').value);
            if (!amount || amount <= 0) {
                alert('Please enter a valid amount.');
                return;
            }

            fetch('@Url.Action("UpdatePayment", "Paybacks")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                body: JSON.stringify({
                    paymentId: currentPaymentId,
                    paidAt: document.getElementById('mdlPayPaidAt').value || null,
                    amount: amount,
                    method: document.getElementById('mdlPayMethod').value,
                    notes: document.getElementById('mdlPayNotes').value || null
                })
            }).then(function (r) {
                if (r.ok) location.reload();
                else r.json().then(function (d) { alert(d.error || 'Failed to save.'); });
            });
        });

        // ── Delete payment ──
        document.getElementById('mdlPayDeleteBtn').addEventListener('click', function () {
            if (!currentPaymentId) return;
            if (!confirm('Delete this payment? This cannot be undone.')) return;

            fetch('@Url.Action("DeletePayment", "Paybacks")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
                body: JSON.stringify({ paymentId: currentPaymentId })
            }).then(function (r) {
                if (r.ok) location.reload();
                else r.json().then(function (d) { alert(d.error || 'Failed to delete.'); });
            });
        });
    </script>
}
