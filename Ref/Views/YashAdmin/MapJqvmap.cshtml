@{
	
    ViewData["Heading"] = "Jqvmap";
}
<div class="content-body">
    <div class="container-fluid">
        <!-- row -->
        <!-- Vectormap -->
        <div class="row">
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">World Map</h4>
                    </div>
                    <div class="card-body">
                        <div id="world-map"></div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">USA</h4>
                    </div>
                    <div class="card-body">
                        <div id="usa" style="height: 450px;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section YashAdmin_style
{
	<!-- Start Page Level CSS -->
	<link href="https://fonts.googleapis.com/css2?family=Material+Icons" rel="stylesheet">
	<!-- Vectormap -->
	<link href="~/yashadmin/vendor/jqvmap/css/jqvmap.min.css" rel="stylesheet">
	<!-- End Page Level CSS -->
}

@section YashAdmin_script
{
	<!--**********************************
		Scripts
	***********************************-->
	<!-- Required vendors -->
    <script src="~/yashadmin/vendor/global/global.min.js"></script>

    <!-- Vectormap -->
    <script src="~/yashadmin/vendor/jqvmap/js/jquery.vmap.min.js"></script>
    <script src="~/yashadmin/vendor/jqvmap/js/jquery.vmap.world.js"></script>
    <script src="~/yashadmin/vendor/jqvmap/js/jquery.vmap.usa.js"></script>
    <script src="~/yashadmin/vendor/bootstrap-select/dist/js/bootstrap-select.min.js"></script>

    <!-- All init script -->
    <script src="~/yashadmin/js/plugins-init/jqvmap-init.js"></script>

    <script src="~/yashadmin/js/custom.min.js"></script>
    <script src="~/yashadmin/js/deznav-init.js"></script>
   
    
}